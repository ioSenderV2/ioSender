<?xml version="1.0" encoding="utf-8"?>
<!--
  ioSender factory-default settings template.

  This is the source of "Reset to Default" for the App / Jogging / G Code settings tabs, and the seed for a
  brand-new install (copied to %AppData%\ioSender\App.config on first run when no user config exists yet).
  It is read-only at runtime - ioSender never writes here; all user edits go to the per-user App.config.

  Edit these values to change the shipped defaults. Only the keys a settings panel can reset need to be present;
  any key omitted here falls back to its built-in code default. Keep the <AppConfig>/<section>/<Config> shape.
-->
<AppConfig version="2">
  <section key="Core">
    <Config>
      <Theme>default</Theme>
      <PollInterval>200</PollInterval>
      <ResetDelay>2000</ResetDelay>
      <MaxBufferSize>300</MaxBufferSize>
      <UseBuffering>false</UseBuffering>
      <KeepMdiFocus>true</KeepMdiFocus>
      <FilterOkResponse>false</FilterOkResponse>
      <AutoCompress>false</AutoCompress>
      <KeepWindowSize>false</KeepWindowSize>
      <SendComments>false</SendComments>
      <PreferNetwork>false</PreferNetwork>
      <AddLineNumbers>false</AddLineNumbers>
      <AutoSaveSettings>false</AutoSaveSettings>
      <PromptOnSave>false</PromptOnSave>
      <AutoSaveGrblSettings>false</AutoSaveGrblSettings>
      <PromptOnGrblSave>false</PromptOnGrblSave>
      <SafeGotoZ>true</SafeGotoZ>
      <RestoreFusionRapids>false</RestoreFusionRapids>
      <IgnoreM6>No</IgnoreM6>
      <IgnoreM7>No</IgnoreM7>
      <IgnoreM8>No</IgnoreM8>
      <IgnoreG61G64>Strip</IgnoreG61G64>
    </Config>
  </section>
  <section key="Jog">
    <JogConfig>
      <KeyboardEnable>true</KeyboardEnable>
      <KeepUiJogSelection>false</KeepUiJogSelection>
      <DefaultSpeedFast>false</DefaultSpeedFast>
      <FastFeedrate>500</FastFeedrate>
      <SlowFeedrate>200</SlowFeedrate>
      <StepFeedrate>100</StepFeedrate>
      <FastDistance>500</FastDistance>
      <SlowDistance>500</SlowDistance>
      <StepDistance>0.05</StepDistance>
    </JogConfig>
  </section>
  <section key="JogUiMetric">
    <JogUIConfig>
      <Feedrate0>5</Feedrate0>
      <Feedrate1>100</Feedrate1>
      <Feedrate2>500</Feedrate2>
      <Feedrate3>1000</Feedrate3>
      <Distance0>0.01</Distance0>
      <Distance1>0.1</Distance1>
      <Distance2>1</Distance2>
      <Distance3>10</Distance3>
    </JogUIConfig>
  </section>
</AppConfig>
