<UserControl x:Class="GCode_Sender.HeightMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:cnccontrols="clr-namespace:CNC.Controls;assembly=CNC.Controls.WPF"
             xmlns:helix="clr-namespace:HelixToolkit.Wpf;assembly=HelixToolkit.Wpf"
             mc:Ignorable="d" d:DesignHeight="560" d:DesignWidth="820">
    <UserControl.Resources>
        <cnccontrols:LogicalNotConverter x:Key="IsNotRunning"/>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" MinWidth="340"/>
            <!-- Dedicated splitter column, not "sit on the col 0/1 boundary" - the latter puts the splitter
                 BEHIND column 0's content (declared first in XAML), which has no margin carved out for it and
                 so swallows its hit-test area entirely (no resize cursor ever appears) - see StartJobView.xaml
                 for the fuller explanation; same fix the Job tab's splitters already use successfully. -->
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Background="#FFCCCCCC" ResizeBehavior="PreviousAndNext" Cursor="SizeWE"/>

        <!-- Left: scrolling inputs on top, warnings + Generate/Apply/Save/Load pinned at the bottom -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="0,0,8,0">
                    <GroupBox x:Uid="hm_grpProbe" Header="Probe">
                        <StackPanel Orientation="Horizontal" Margin="6,4">
                            <Label x:Uid="hm_lblProbe" Content="Probe:" MinWidth="90" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                            <ComboBox x:Uid="cbxProbe" x:Name="cbxProbe" MinWidth="200" MinHeight="22" VerticalAlignment="Center" DisplayMemberPath="Name" SelectionChanged="cbxProbe_SelectionChanged"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Uid="hm_grpArea" Header="Area to probe" Margin="0,6,0,0">
                        <StackPanel Margin="6">
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Uid="hm_areaProgram" x:Name="rbAreaProgram" Content="From program" GroupName="hmarea" IsChecked="True"
                                             VerticalAlignment="Center" Checked="AreaProgram_Checked"
                                             ToolTip="Probe over the loaded job's XY extent, in the current work coordinates."/>
                                <RadioButton x:Uid="hm_areaTable" x:Name="rbAreaTable" Content="Full table" GroupName="hmarea" Margin="18,0,0,0"
                                             VerticalAlignment="Center" Checked="AreaTable_Checked"
                                             ToolTip="Probe the whole in-bounds machine travel envelope (referenced to the homed corner, like Surface spoilboard)."/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <cnccontrols:NumericField Label="X:" ColonAt="20" Format="-####0.0##"
                                    Value="{Binding HeightMap.MinX, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}"/>
                                <cnccontrols:NumericField x:Uid="hm_width" Label="W:" ColonAt="25" Format="-####0.0##" Margin="8,0,0,0"
                                    Value="{Binding HeightMap.Width, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <cnccontrols:NumericField Label="Y:" ColonAt="20" Format="-####0.0##"
                                    Value="{Binding HeightMap.MinY, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}"/>
                                <cnccontrols:NumericField x:Uid="hm_height" Label="H:" ColonAt="25" Format="-####0.0##" Margin="8,0,0,0"
                                    Value="{Binding HeightMap.Height, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}"/>
                            </StackPanel>
                            <Button x:Uid="hm_fromLimits" Content="Set from program limits" Margin="0,6,0,0" Padding="5,0"
                                    HorizontalAlignment="Left" IsEnabled="{Binding IsFileLoaded}" Click="Limits_Click"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Uid="hm_grpGrid" Header="Grid size" Margin="0,6,0,0">
                        <StackPanel Margin="6">
                            <StackPanel Orientation="Horizontal">
                                <cnccontrols:NumericField Label="X:" ColonAt="25" Format="###0.0##"
                                    Value="{Binding HeightMap.GridSizeX, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}"/>
                                <cnccontrols:NumericField Label="Y:" ColonAt="25" Format="###0.0##" Margin="8,0,0,0"
                                    Value="{Binding HeightMap.GridSizeY, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}"/>
                                <CheckBox x:Uid="hm_lock" Content="Lock" Margin="12,0,0,0" VerticalAlignment="Center"
                                    IsChecked="{Binding HeightMap.GridSizeLockXY, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Uid="hm_grpProbing" Header="Probing" Margin="0,6,0,0">
                        <StackPanel Margin="6">
                            <cnccontrols:NumericField x:Uid="hm_depth" Label="Probe depth:" ColonAt="90" Unit="mm" Format="###0.0##"
                                ToolTip="How far DOWN from the parked (start) Z each probe searches before it faults. Park Z at a small safe clearance above the surface, then this must be at least that clearance plus the surface variation."
                                Value="{Binding HeightMap.ProbeDepth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}"/>
                            <cnccontrols:NumericField x:Uid="hm_feed" Label="Probe feed:" ColonAt="90" Unit="mm/min" Format="#####0" Margin="0,4,0,0"
                                ToolTip="Feed for every probe. The surface is already roughly known, so all points probe gently at this single approach feed - no fast search pass - which avoids overshoot/false triggers on a fragile probe. Defaults to the probe's latch (slow) feed."
                                Value="{Binding HeightMap.ProbeFeed, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}"/>
                            <cnccontrols:NumericField x:Uid="hm_dwell" Label="Settle dwell:" ColonAt="90" Unit="s" Format="##0.0##" Margin="0,4,0,0"
                                ToolTip="Pause before each probe so a fragile/3D probe fully releases and stops ringing after the previous touch and the move. Raise this if you get 'probe already triggered' fails partway through. 0 = none."
                                Value="{Binding HeightMap.SettleDwell, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="1" Margin="0,8,8,0">
                <TextBlock x:Name="txtNoProbe" Foreground="#C0392B" TextWrapping="Wrap" Visibility="Collapsed"
                           Text="No probe defined. Add a 3D probe, touch plate or edge finder in Machine Setup Wizard &gt; Probe definitions."/>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <Button x:Uid="hm_start" Content="Start" MinWidth="70" MinHeight="26" Click="Start_Click"
                            IsEnabled="{Binding IsJobRunning, Converter={StaticResource IsNotRunning}}"
                            ToolTip="Start probing the height map grid."/>
                    <Button x:Uid="hm_stop" Content="Stop" MinWidth="70" MinHeight="26" Margin="8,0,0,0" Click="Stop_Click"
                            IsEnabled="{Binding IsJobRunning}"
                            ToolTip="Cancel the height map probing in progress."/>
                    <Button x:Uid="hm_apply" Content="Apply" MinWidth="70" MinHeight="26" Margin="8,0,0,0" Click="Apply_Click"
                            IsEnabled="{Binding HeightMap.CanApply, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                            ToolTip="Rewrite the loaded program to follow the probed surface."/>
                    <Button x:Uid="hm_save" Content="Save" MinWidth="70" MinHeight="26" Margin="8,0,0,0" Click="Save_Click"
                            ToolTip="Save the height map to a file (.map) to reuse later."/>
                    <Button x:Uid="hm_load" Content="Load" MinWidth="70" MinHeight="26" Margin="8,0,0,0" Click="Load_Click"
                            ToolTip="Load a previously saved height map (.map) file."/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Right: steps/help on top, 3D view of the planned grid / probed surface (blue low -> red high) below -->
        <Grid Grid.Column="2" Margin="8,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <GroupBox x:Uid="hm_grpSteps" Header="Steps" Grid.Row="0" Margin="0,0,0,8">
                <TextBlock x:Uid="hm_steps" Margin="8" TextWrapping="Wrap" LineHeight="18">
                    <Run FontWeight="Bold" Text="1. Set the work origin on the stock."/>
                    <Run Text=" Probing happens in the current work coordinates, so jog to the stock corner and zero X/Y (the Load stock tab can do this). The area below is in those work coordinates, so this is how it knows where the stock is."/>
                    <LineBreak/>
                    <Run FontWeight="Bold" Text="2. Choose the area + grid."/>
                    <Run Text=" 'From program' covers the loaded job's footprint (load it, then 'Set from program limits'); 'Full travel' covers the machine bed. Edit X/Y/W/H to fine-tune. Smaller grid = denser and slower (a gently-curved spoilboard often needs only 3x3 or 4x4)."/>
                    <LineBreak/>
                    <Run FontWeight="Bold" Text="3. Pick the probe + jog Z to a safe clearance."/>
                    <Run Text=" Park Z a few mm above the surface - the probe descends from there and retracts back to it between points. Probe depth is how far DOWN to search (at least the clearance plus the surface variation). Probe feed is the gentle approach speed; Settle dwell pauses before each probe for a fragile probe to release."/>
                    <LineBreak/>
                    <Run FontWeight="Bold" Text="4. Start."/>
                    <Run Text=" Probes the grid one point at a time (Stop cancels); the surface draws here when it finishes."/>
                    <LineBreak/>
                    <Run FontWeight="Bold" Text="5. Apply / Save."/>
                    <Run Text=" Apply rewrites the loaded program to follow the surface. Save stores the map (.map) to reuse later (Load)."/>
                </TextBlock>
            </GroupBox>

            <GroupBox x:Uid="hm_grpView" Header="Surface" Grid.Row="1">
            <helix:HelixViewport3D x:Name="viewport" ZoomExtentsWhenLoaded="True"
                                   RotateAroundMouseDownPoint="True" ZoomAroundMouseDownPoint="True">
                <helix:HelixViewport3D.Camera>
                    <PerspectiveCamera Position="0,0,100" LookDirection="0,0,-100" UpDirection="0,1,0.5" FieldOfView="61" NearPlaneDistance="0.001"/>
                </helix:HelixViewport3D.Camera>
                <helix:DefaultLights/>
                <helix:MeshGeometryVisual3D MeshGeometry="{Binding HeightMap.MeshGeometry, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}">
                    <helix:MeshGeometryVisual3D.Material>
                        <MaterialGroup>
                            <DiffuseMaterial>
                                <DiffuseMaterial.Brush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1" Opacity="0.5">
                                        <LinearGradientBrush.GradientStops>
                                            <GradientStop Color="Blue" Offset="0"/>
                                            <GradientStop Color="Cyan" Offset="0.2"/>
                                            <GradientStop Color="Green" Offset="0.4"/>
                                            <GradientStop Color="Yellow" Offset="0.6"/>
                                            <GradientStop Color="Red" Offset="0.8"/>
                                            <GradientStop Color="Purple" Offset="1"/>
                                        </LinearGradientBrush.GradientStops>
                                    </LinearGradientBrush>
                                </DiffuseMaterial.Brush>
                            </DiffuseMaterial>
                        </MaterialGroup>
                    </helix:MeshGeometryVisual3D.Material>
                </helix:MeshGeometryVisual3D>
                <helix:LinesVisual3D Thickness="1" Color="Lime" Points="{Binding HeightMap.BoundaryPoints, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
                <helix:PointsVisual3D Size="4" Color="Red" Points="{Binding HeightMap.MapPoints, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"/>
            </helix:HelixViewport3D>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
