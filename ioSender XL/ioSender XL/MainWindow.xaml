<Window x:Class="GCode_Sender.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        xmlns:cnccore="clr-namespace:CNC.Core;assembly=CNC.Core"
        xmlns:cnccontrols="clr-namespace:CNC.Controls;assembly=CNC.Controls.WPF"
        xmlns:cncviewer="clr-namespace:CNC.Controls.Viewer;assembly=CNC.Controls.Viewer"
        xmlns:cnclathecontrols="clr-namespace:CNC.Controls.Lathe;assembly=CNC.Controls.Lathe"
        xmlns:cncprobingcontrols="clr-namespace:CNC.Controls.Probing;assembly=CNC.Controls.Probing"
        xmlns:local="clr-namespace:GCode_Sender"
        mc:Ignorable="d"
        Background="#FFE5E5E5"
        Title="Sender ({0})" Height="640" Width="925" MinHeight="700" MinWidth="1250"
        Opacity="0" ShowInTaskbar="False"
        Loaded="Window_Load"
        SizeChanged="Window_SizeChanged"
        Closing="Window_Closing"
        Closed="Window_Closed" Icon="App.ico">
    <Window.Resources>
        <system:String x:Uid="str_mnuRotate" x:Key="MenuRotate">Rotate</system:String>
        <system:String x:Uid="str_mnuArcsToLines" x:Key="MenuArcsToLines">Arcs to lines</system:String>
        <system:String x:Uid="str_mnuCompress" x:Key="MenuCompress">Compress (experimental)</system:String>
        <system:String x:Uid="str_mnuDragKnife" x:Key="MenuDragKnife">Add drag knife moves</system:String>
        <system:String x:Uid="str_jogStep" x:Key="JogStep">Jog step: {0}</system:String>
        <system:String x:Uid="str_runTime" x:Key="RunTime">Run time: {0}</system:String>
        <cnccontrols:BlocksToStringConverter x:Key="BlocksToStringConverter" />
        <cnccontrols:LogicalNotConverter x:Key="BooleanConverter" />
    </Window.Resources>
    <Window.DataContext>
        <cnccore:GrblViewModel />
    </Window.DataContext>
    <DockPanel VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <DockPanel.LayoutTransform>
            <!-- Whole-app UI scale (Settings:App) - live, no restart. Bound to the static config
                 singleton (not Window.DataContext, which is GrblViewModel) so it scales the entire
                 window - menu, panels, everything - together. -->
            <ScaleTransform ScaleX="{Binding Source={x:Static cnccontrols:AppConfig.Settings}, Path=Base.UiScale}"
                            ScaleY="{Binding Source={x:Static cnccontrols:AppConfig.Settings}, Path=Base.UiScale}"/>
        </DockPanel.LayoutTransform>
        <!-- Menu-overhaul: the File menu is dissolved. Connect/Reconnect is now a top-level item; Load/Load
             Folder/Save/Close live on the program view, Open Console is a double-click on the Console tab,
             and Transform is in the program list's right-click menu. Exit is dropped - the window X / Alt+F4
             (both routed through Window_Closing) quit the app. -->
        <Menu x:Name="menuMain" IsEnabled="{Binding Path=IsJobRunning, Converter={StaticResource BooleanConverter}}" DockPanel.Dock="Top">
            <MenuItem x:Uid="mnu_connect" x:Name="menuConnect" Header="Co_nnect..." Click="connectMenuItem_Click"/>
            <MenuItem x:Uid="mnu_camera" x:Name="menuCamera" Header="_Camera">
                <MenuItem x:Uid="mnu_open" Header="_Open" Click="CameraOpen_Click"/>
            </MenuItem>
            <MenuItem x:Uid="mnu_help" x:Name="menuHelp" Header="_Help">
                <MenuItem x:Uid="mnu_wiki" Header="_Wiki" Click="aboutWikiItem_Click"/>
                <MenuItem x:Uid="mnu_usageTips" Header="Usage _tips" Click="tipsWikiItem_Click"/>
                <MenuItem x:Uid="mnu_briefTour" Header="A _brief tour" Click="briefTour_Click"/>
                <MenuItem x:Uid="mnu_videoTutorials" Header="_Video tutorials" Click="videoTutorials_Click"/>
                <MenuItem x:Uid="mnu_errorsAndAlarms" Header="_Error and alarm codes" Click="errorAndAlarms_Click"/>
                <Separator/>
                <MenuItem x:Uid="mnu_support" x:Name="menuSupport" Header="_Support">
                    <MenuItem x:Uid="mnu_checkForUpdates" Header="_Check for updates..." Click="checkForUpdates_Click" ToolTip="Check if a newer version of ioSender is available on GitHub."/>
                    <MenuItem x:Uid="mnu_rollbackVersion" Header="_Roll back to previous version..." Click="rollbackVersion_Click" ToolTip="Swap back to the ioSender build installed before the last update. Only goes back one version - it does not work if you have not updated at least once."/>
                    <MenuItem x:Uid="mnu_openConfigFolder" Header="Open Application _data folder" Click="openConfigFolderMenuItem_Click" ToolTip="Open the per-user folder where ioSender keeps its settings (App.config), key mappings, grbl backups and restore points."/>
                    <MenuItem x:Uid="mnu_generateResetTestCase" Header="Generate _reset test case..." Click="generateResetTestCase_Click" ToolTip="Write a .nc file that calls an O-word subroutine several times, for reproducing controller-wedge-on-Reset bugs." Visibility="Collapsed"/>
                </MenuItem>
                <MenuItem x:Uid="mnu_about" Header="_About" Click="aboutMenuItem_Click"/>
            </MenuItem>
        </Menu>
        <!-- Menu-overhaul: the toolbar row (file-action icons + quick-run macro buttons) was removed. The
             file icons duplicated the program-view header (Load/Close) or were dropped (Reload/Edit); macros
             still run by F-key (KeypressHandler) - a macro-name flyout is a possible future replacement. -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="120" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem>
                <TextBlock TextWrapping="NoWrap">
                    <TextBlock.Text>
                        <MultiBinding Converter="{StaticResource BlocksToStringConverter}">
                            <Binding Path="Blocks" />
                            <Binding Path="BlockExecuting" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StatusBarItem>
            <Separator Grid.Column="1" />
            <StatusBarItem Grid.Column="2">
                <!-- msgFlashBorder: a new Message briefly flashes this background light green (normal) or
                     light red (error, GrblViewModel.IsMessageError) for 5s - see MainWindow.xaml.cs's
                     FlashMessage - instead of the old enlarge/shrink-font animation, which shifted the whole
                     window layout up/down every time a message arrived. lblMessage's font is now permanently
                     large (doubled once at startup, see MainWindow_Loaded) rather than only during that window. -->
                <Border x:Name="msgFlashBorder" Background="Transparent" Padding="2,0">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Uid="btn_copyMessage" x:Name="btnCopyMessage" Click="CopyMessage_Click" Cursor="Hand"
                                ToolTip="Copy the full status message to the clipboard" Focusable="False"
                                Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,5,0" VerticalAlignment="Center">
                            <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#FF555555"/>
                        </Button>
                        <TextBlock x:Uid="lbl_message" x:Name="lblMessage" Text="{Binding Path=Message}" TextWrapping="NoWrap"
                                   VerticalAlignment="Center" ToolTipService.ShowDuration="60000" ToolTipService.InitialShowDelay="300">
                            <TextBlock.ToolTip>
                                <TextBlock Text="{Binding Path=Message}" TextWrapping="Wrap" MaxWidth="540"/>
                            </TextBlock.ToolTip>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StatusBarItem>
            <Separator Grid.Column="3" />
            <StatusBarItem Grid.Column="4">
                <TextBlock x:Uid="lbl_connectionTarget" TextWrapping="NoWrap" Padding="4,0" FontWeight="SemiBold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <!-- green when a target is connected, red when not. Text is a Setter (not a local
                                 value) so the IsConnectionLost trigger below can override it - a directly set
                                 Text binding would win over a trigger and never show "Not connected". -->
                            <Setter Property="Text" Value="{Binding Path=ConnectionTarget, StringFormat=Target: {0}, TargetNullValue=Not connected}"/>
                            <Setter Property="Foreground" Value="ForestGreen"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Path=ConnectionTarget}" Value="{x:Null}">
                                    <Setter Property="Foreground" Value="Red"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Path=ConnectionTarget}" Value="">
                                    <Setter Property="Foreground" Value="Red"/>
                                </DataTrigger>
                                <!-- socket dropped (e.g. simulator closed): the reconnect loop keeps the
                                     target name set, so reflect the lost state here instead -->
                                <DataTrigger Binding="{Binding Path=IsConnectionLost}" Value="True">
                                    <Setter Property="Foreground" Value="Red"/>
                                    <Setter Property="Text" Value="Not connected"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <TextBlock.ContextMenu>
                        <ContextMenu Opened="targetContextMenu_Opened">
                            <MenuItem x:Uid="mnu_validate" Header="_Validate controller..." Click="validateMenuItem_Click"/>
                        </ContextMenu>
                    </TextBlock.ContextMenu>
                </TextBlock>
            </StatusBarItem>
            <Separator Grid.Column="5" />
            <StatusBarItem Grid.Column="6">
                <TextBlock x:Uid="lbl_runtime" Text="{Binding Path=RunTime, StringFormat={StaticResource RunTime}}" TextWrapping="NoWrap" Padding="2,0"/>
            </StatusBarItem>
            <Separator Grid.Column="7" />
            <StatusBarItem Grid.Column="8">
                <TextBlock x:Uid="lbl_jogStep" ToolTip="Distance for keyboard step jog (with &lt;CTRL&gt; modifier)." Text="{Binding Path=JogStep, StringFormat={StaticResource JogStep}}" HorizontalAlignment="Right" TextWrapping="NoWrap" Margin="4,0"/>
            </StatusBarItem>
        </StatusBar>
        <!-- Single, always-visible machine-control cluster (Phase 2c) - replaced the former floating
             run-control window and the Grbl-tab's lower-left controls. Signals + Status (state/check +
             Home/Unlock/Reset) + JobControl (Cycle Start [starts a job] / Feed Hold / Stop / Rewind) +
             Feed/rapid override + MDI. Docked just above the status bar, full width, present on every tab so
             Feed Hold / Stop / MDI are always reachable regardless of the active tab. -->
        <Border x:Name="runControlBorder" DockPanel.Dock="Bottom" BorderBrush="#FFCCCCCC" BorderThickness="0,1,0,0" Background="#FFF5F5F5">
            <Grid Margin="6,4">
                <!-- Four columns: [button row | jog pad | signals+feed | overrides]. The button-row column is the
                     star, so it grows to consume the slack up to the jog pad; the other three are content-sized and
                     ride at the right edge, adjacent to each other. -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Button-row region (col 0, star): three lines (MDI / run buttons / State), left-aligned; the
                     column grows to fill the slack up to the jog pad. -->
                <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                        <!-- MDI line: width tied to the button row so its right edge (Send) aligns with Program. -->
                        <cnccontrols:MDIControl x:Name="mdiControl" Bare="True" HorizontalAlignment="Left" Margin="0,5,0,0"
                                                Width="{Binding ElementName=buttonRow, Path=ActualWidth}"/>
                        <!-- Button line: the row stretches to fill the star column so its right edge (Program) meets
                             the jog pad; the three groups (status / job / program) are pushed apart by star spacers
                             so the run buttons span the width instead of huddling at the left. -->
                        <Grid x:Name="buttonRow" Margin="0,7,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <cnccontrols:StatusControl Grid.Column="0" ShowState="False" VerticalAlignment="Top"/>
                            <cnccontrols:JobControl Grid.Column="2" x:Name="runControl" VerticalAlignment="Top"/>
                            <ToggleButton x:Uid="btnProgramView" Grid.Column="4" x:Name="btnProgramView" Content="Program" Height="36" Padding="12,0" VerticalAlignment="Top" Focusable="False" IsEnabled="False" ToolTip="Show/hide the program view over the work area." Checked="ProgramView_Toggled" Unchecked="ProgramView_Toggled"/>
                        </Grid>
                        <!-- State: / Check directly under Home/Unlock/Reset, with the Jog distance/feed preset
                             spinners on the same line. Width is tied to the button row so the selector's right
                             edge ("Feed") aligns with the Program button's right edge above. -->
                        <Grid Margin="0,7,0,0" Width="{Binding ElementName=buttonRow, Path=ActualWidth}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                <cnccontrols:StatusControl ShowButtons="False" VerticalAlignment="Center"/>
                                <!-- Demo-video timelapse marker toggle, right of the State field. Hidden unless
                                     launched with -demomarker (visibility set in MainWindow.xaml.cs). Marks
                                     TIMELAPSE_ON/OFF into the demo marker file; see docs/demo-videos. -->
                                <ToggleButton x:Uid="btnTimeLapse" x:Name="btnTimeLapse" Content="Timelapse" MinWidth="80" Margin="12,0,0,0" VerticalAlignment="Center" Focusable="False" Visibility="Collapsed" ToolTip="Demo capture: mark the timelapse window. Flip ON at the moment you switch the camera to timelapse, OFF when you switch back. Auto-ON a few minutes after Run if you don't; auto-OFF at job end." Checked="TimeLapse_Toggled" Unchecked="TimeLapse_Toggled">
                                    <!-- Traffic-light coloring (not the selection highlight): green when OFF
                                         (press to start), red when RUNNING (press to stop). Custom template so
                                         Background is honored in the checked state. -->
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Background" Value="#2E7D32"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="8,3" SnapsToDevicePixels="True">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Background" Value="#C62828"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                                <!-- Run-bar copy of OBS Control's "All" toggle - same ObsBridge.SetCameraRecording
                                     state as the panel (RtspCamerasControl), placed here so it's reachable without
                                     having to place that panel via Edit Main Page. Hidden unless -demomarker (same
                                     visibility gate as Timelapse, set alongside it in MainWindow.xaml.cs). -->
                                <ToggleButton x:Uid="btnAllRecord" x:Name="btnAllRecord" MinWidth="36" Margin="6,0,0,0" VerticalAlignment="Center" Focusable="False" Visibility="Collapsed" ToolTip="OBS Control - All: click to start/stop every camera together" Style="{StaticResource RecordToggleStyle}" Checked="AllRecord_Toggled" Unchecked="AllRecord_Toggled"/>
                            </StackPanel>
                            <cnccontrols:JogPresetSelector Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                <!-- Jog pad (col 1): shrunk arrows-only copy of the Jog-tab control (selection shared via JogData),
                     riding at the left of the right-hand group, just past the button-row column. -->
                <cnccontrols:JogBaseControl x:Name="jogPad" Grid.Column="1" ArrowsOnly="True" Margin="18,0,10,0" VerticalAlignment="Center">
                    <cnccontrols:JogBaseControl.LayoutTransform>
                        <ScaleTransform ScaleX="0.65" ScaleY="0.65"/>
                    </cnccontrols:JogBaseControl.LayoutTransform>
                </cnccontrols:JogBaseControl>
                <!-- Signals (col 2): indicators (flush to top) + current feed rate under them; butts against the jog pad. -->
                <StackPanel Grid.Column="2" Orientation="Vertical" Margin="0" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <cnccontrols:SignalsControl VerticalAlignment="Top" Margin="0">
                        <cnccontrols:SignalsControl.LayoutTransform>
                            <ScaleTransform ScaleX="0.86" ScaleY="0.86"/>
                        </cnccontrols:SignalsControl.LayoutTransform>
                    </cnccontrols:SignalsControl>
                    <StackPanel Orientation="Horizontal" Margin="2,4,0,0">
                        <Label Content="Feed:" Padding="0" VerticalAlignment="Center"/>
                        <cnccontrols:NumericTextBox Value="{Binding Path=FeedRate, Mode=OneWay}" Format="####0" IsReadOnly="True" Focusable="False" MinWidth="52" Margin="4,0,0,0" VerticalAlignment="Center"/>
                        <Label Content="{Binding Path=FeedrateUnit, Mode=OneWay}" Padding="2,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                <!-- Right: feed / rapids override controls, given ~25% more room. -->
                <cnccontrols:FeedControl Grid.Column="3" OverridesOnly="True" Margin="10,0,4,0" VerticalAlignment="Center">
                    <cnccontrols:FeedControl.LayoutTransform>
                        <ScaleTransform ScaleX="0.82" ScaleY="0.82"/>
                    </cnccontrols:FeedControl.LayoutTransform>
                </cnccontrols:FeedControl>
            </Grid>
        </Border>
        <Canvas x:Name="sidebarCanvas" DockPanel.Dock="Right" Width="22" VerticalAlignment="Stretch" HorizontalAlignment="Right" ClipToBounds="False" Panel.ZIndex="1" Margin="0,34,0,0">
            <ItemsControl x:Name="xx" Width="22" VerticalAlignment="Stretch">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel IsEnabled="{Binding Path=IsJobRunning, Converter={StaticResource BooleanConverter}}" Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Top" Width="22"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
            <!-- Always-flyouts (no main-page form). Goto/Outline and the other pool panels are added
                 dynamically in code-behind when not placed in a main-page slot. -->
            <cnccontrols:MacroExecuteControl x:Name="macroControl" Visibility="Hidden" Canvas.Right="22"/>
            <cnccontrols:MachinePositionFlyout x:Name="mposFlyout" Visibility="Hidden" Canvas.Right="22"/>
            <cnccontrols:THCMonitorControl x:Name="thcControl" Visibility="Hidden" Canvas.Right="22"/>
        </Canvas>
        <Grid DockPanel.Dock="Left">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- StretchTabControl spreads the tab headers across the full strip width (proportional to each
             label). Recomputes only on tab add/remove and a deferred, post-layout resize callback. -->
        <cnccontrols:StretchTabControl Grid.ColumnSpan="3" IsEnabled="{Binding Path=IsMPGActive, Converter={StaticResource BooleanConverter}}" Background="Transparent" x:Name="tabMode" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Focusable="False" SelectionChanged="TabMode_SelectionChanged">
            <cnccontrols:StretchTabControl.Resources>
                <!-- Apple-flavored main-nav tab: a floating rounded pill for the selected tab (macOS System
                     Settings sidebar style), flat/transparent for unselected ones. Tabs deliberately do NOT
                     use the per-panel functional color system (Position/Jogging/Feed/Coolant) - a tab like
                     "Job" contains ALL of those categories at once, so no single category color describes
                     it correctly. Selected uses the accent's own "light" ramp tier (base 55% + white 45%),
                     NOT the same solid blue as the primary action button - navigation/"you are here" needs
                     to read as visually distinct from "click me," and it fixes a real contrast problem the
                     solid-blue version had (dark text on solid accent blue was hard to read). Base accent
                     blue is reused as the selected tab's TEXT color on top of that light fill, same pattern
                     as the functional-category buttons (base = ink text on the derived light background).
                     This is still navigation chrome, a third, separate use of color from both the primary-
                     action rule and the functional-panel rule. One ContentPresenter throughout
                     (x:Name="header") - StretchTabControl.ApplySelectionEmphasis finds it by walking the
                     visual tree for the first ContentPresenter and bolds/enlarges it on selection, so a
                     second one for the "selected" state would silently break that.

                     Earlier pass used a flared/mesa Path shape here - looked good in isolated mockups but
                     wrong in the real app, reverted to a plain pill.

                     KEYED + applied via ItemContainerStyle, not implicit/keyless: an implicit TargetType-only
                     style here would leak into every OTHER TabControl's TabItems nested anywhere inside this
                     one's content (e.g. JobWorkspace's Program/3D View/Console TabControl) - WPF's implicit
                     style lookup walks the LOGICAL tree, and a tab's content is logically parented under the
                     TabItem that hosts it, so it doesn't stop at this control's own boundary. -->
                <Style x:Key="MainNavTabItemStyle" TargetType="{x:Type TabItem}">
                    <Setter Property="MinHeight" Value="34" />
                    <Setter Property="MinWidth" Value="40" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type TabItem}">
                                <Border x:Name="pill" CornerRadius="8" Margin="2,3" Background="Transparent" SnapsToDevicePixels="True">
                                    <ContentPresenter x:Name="header" ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Margin="10,5" TextElement.Foreground="#FF48484A"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="pill" Property="Background" Value="{StaticResource AppleAccentLightBrush}"/>
                                        <Setter TargetName="pill" Property="Effect" Value="{StaticResource ButtonShadowDefault}"/>
                                        <Setter TargetName="header" Property="TextElement.Foreground" Value="{StaticResource AppleAccentBrush}"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                            <Condition Property="IsSelected" Value="False"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="pill" Property="Background" Value="#14000000"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </cnccontrols:StretchTabControl.Resources>
            <!-- Set here (property-element, after Resources) rather than as an attribute on the opening tag:
                 StaticResource is resolved in document order, and an attribute on the opening tag is parsed
                 before this element's own Resources child block registers MainNavTabItemStyle - same "target
                 must appear before" rule as ControlTemplate.Triggers TargetName above. As an attribute this
                 threw 'Provide value on StaticResourceExtension' at startup. -->
            <cnccontrols:StretchTabControl.ItemContainerStyle>
                <StaticResource ResourceKey="MainNavTabItemStyle"/>
            </cnccontrols:StretchTabControl.ItemContainerStyle>
            <!-- Tabs are built in code from TabRegistry (Phase 1: MainWindow is a container).
                 See RegisterBuiltinTabs()/BuildTabs() in MainWindow.xaml.cs. -->
        </cnccontrols:StretchTabControl>
        <!-- On-demand overlays over the tab content (above the run bar). Toggled in MainWindow.xaml.cs. -->
        <!-- Program view always pops on the RIGHT, occupying exactly the rightmost third of the
             client area (Grid.Column="2" of the 3 equal columns above) - was a fixed 560-720px
             MinWidth/MaxWidth before, which ran over half the client area on a narrower window. -->
        <Border x:Name="overlayProgram" Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0,60,0,0"
                Visibility="Collapsed" Background="White" BorderBrush="#FF888888" BorderThickness="1" Panel.ZIndex="2">
            <!-- Hosts whichever tool's own ProgramView is connected (Load File/Folder, or a wizard's Generate
                 output) - each carries its own title bar. Nothing shows here (and the "Program" button is
                 disabled) when nothing is connected; the loaded job's own docked list (ProgramPanel, in the
                 Job tab) is the persistent view of that content, so this popup never duplicates it. -->
            <ContentControl x:Name="overlayActiveHost"/>
        </Border>
        <!-- Console log pops directly ABOVE the command box, matching its width (Esc dismisses). -->
        <Border x:Name="overlayConsole" Grid.ColumnSpan="3" HorizontalAlignment="Left" VerticalAlignment="Bottom" Height="300" Margin="6,0,0,0"
                Width="{Binding ElementName=mdiControl, Path=ActualWidth}"
                Visibility="Collapsed" Background="White" BorderBrush="#FF888888" BorderThickness="1" Panel.ZIndex="2">
            <cnccontrols:ConsoleControl x:Name="overlayConsoleView" LogOnly="True"/>
        </Border>
        </Grid>
    </DockPanel>
</Window>
