<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.6.2"/>
    </startup>
    <runtime>
        <!-- Enable WPF per-monitor DPI scaling (pairs with PerMonitorV2 in app.manifest). false = DO re-scale
             the visual tree on a DPI change instead of leaving it at the launch DPI. -->
        <AppContextSwitchOverrides value="Switch.System.Windows.DoNotScaleForDpiChanges=false"/>
    </runtime>
</configuration>
