<UserControl x:Class="GCode_Sender.JobWorkspace"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:cnccontrols="clr-namespace:CNC.Controls;assembly=CNC.Controls.WPF"
             xmlns:cncviewer="clr-namespace:CNC.Controls.Viewer;assembly=CNC.Controls.Viewer"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <!-- The center "workspace": the loaded program (list), the 3D toolpath view, and the console.
         Extracted from JobView (Phase 2a) so the center is a self-contained, relocatable control.
         The three controls are independent: GCodeListControl/RenderControl read the static GCode.File,
         ConsoleControl uses the inherited GrblViewModel DataContext. -->
    <TabControl x:Name="tabGCode" TabStripPlacement="Bottom">
        <TabItem x:Uid="tab_program" Header="Program">
            <cnccontrols:GCodeListControl/>
        </TabItem>
        <TabItem x:Uid="tab_3DView" x:Name="tab3D" Header="3D View">
            <cncviewer:RenderControl x:Name="gcodeRenderer"/>
        </TabItem>
        <TabItem x:Uid="tab_console" x:Name="tabConsole" Header="Console">
            <cnccontrols:ConsoleControl/>
        </TabItem>
    </TabControl>
</UserControl>
