<UserControl x:Class="GCode_Sender.JobWorkspace"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:cnccontrols="clr-namespace:CNC.Controls;assembly=CNC.Controls.WPF"
             xmlns:cncviewer="clr-namespace:CNC.Controls.Viewer;assembly=CNC.Controls.Viewer"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <!-- The center "workspace": the loaded program (list), the 3D toolpath view, and the console.
         Extracted from JobView (Phase 2a). The tabs are built in code from the layout tree's Grbl/"center"
         slot (Phase 2b step 4) - see RegisterCenter()/BuildCenter() in the code-behind. The three controls
         are independent: GCodeListControl/RenderControl read the static GCode.File, ConsoleControl uses the
         inherited GrblViewModel DataContext. -->
    <TabControl x:Name="tabGCode" TabStripPlacement="Bottom"/>
</UserControl>
