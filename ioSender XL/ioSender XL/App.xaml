<Application x:Class="GCode_Sender.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:GCode_Sender"
             xmlns:cnccontrols="clr-namespace:CNC.Controls;assembly=CNC.Controls.WPF">
    <Application.Resources>
        <local:ProgramSourceConverter x:Key="ProgramSource"/>
        <!-- ToolTips render in their own Popup, outside MainWindow's LayoutTransform-scaled visual tree
             (see DialogScaling.cs for the same gotcha with dialog windows) - without this they stay at
             1x regardless of the app's UiScale zoom, unreadably small at high zoom. Implicit style (no
             x:Key) so it applies to every ToolTip app-wide, including ones auto-generated from a plain
             ToolTip="..." string. -->
        <Style TargetType="ToolTip">
            <Setter Property="LayoutTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="{Binding Source={x:Static cnccontrols:AppConfig.Settings}, Path=Base.UiScale}"
                                    ScaleY="{Binding Source={x:Static cnccontrols:AppConfig.Settings}, Path=Base.UiScale}"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="btnSidebar">
            <Setter Property="Background" Value="#FFEFEFEF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" BorderThickness="1" BorderBrush="DarkGray">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
