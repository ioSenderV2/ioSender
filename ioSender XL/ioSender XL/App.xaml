<Application x:Class="GCode_Sender.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:GCode_Sender"
             xmlns:cnccontrols="clr-namespace:CNC.Controls;assembly=CNC.Controls.WPF">
    <Application.Resources>
        <local:ProgramSourceConverter x:Key="ProgramSource"/>
        <!-- ToolTips render in their own Popup, outside MainWindow's LayoutTransform-scaled visual tree
             (see DialogScaling.cs for the same gotcha with dialog windows) - without this they stay at
             1x regardless of the app's UiScale zoom, unreadably small at high zoom. Implicit style (no
             x:Key) so it applies to every ToolTip app-wide, including ones auto-generated from a plain
             ToolTip="..." string. -->
        <Style TargetType="ToolTip">
            <Setter Property="LayoutTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="{Binding Source={x:Static cnccontrols:AppConfig.Settings}, Path=Base.UiScale}"
                                    ScaleY="{Binding Source={x:Static cnccontrols:AppConfig.Settings}, Path=Base.UiScale}"/>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Camera-app record/stop glyph, not a colored button: a red circle (idle - press to start)
             swaps to a red square (recording - press to stop) via an IsChecked trigger. Both shapes
             stay in the template always; only Visibility toggles, so there's no ContentPresenter/Content
             dependency. Shared by RtspCamerasControl's per-camera/All toggles and MainWindow's run-bar
             "All" button (btnAllRecord) - both drive/reflect the same CNC.Core.ObsBridge state. -->
        <Style x:Key="RecordToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="#22000000" CornerRadius="14" SnapsToDevicePixels="True">
                            <Grid>
                                <Ellipse x:Name="RecordDot" Width="14" Height="14" Fill="Red"/>
                                <Rectangle x:Name="StopSquare" Width="12" Height="12" Fill="Red" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RecordDot" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="StopSquare" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="btnSidebar">
            <Setter Property="Background" Value="#FFEFEFEF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" BorderThickness="1" BorderBrush="DarkGray">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
