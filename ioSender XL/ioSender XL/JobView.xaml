<UserControl x:Class="GCode_Sender.JobView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:GCode_Sender"
             xmlns:cnccontrols="clr-namespace:CNC.Controls;assembly=CNC.Controls.WPF"
             xmlns:cncviewer="clr-namespace:CNC.Controls.Viewer;assembly=CNC.Controls.Viewer"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1600"
             Focusable="True"
             Loaded="JobView_Load"
             IsVisibleChanged="JobView_IsVisibleChanged"
             FocusVisualStyle="{x:Null}"
             SizeChanged="JobView_SizeChanged">
    <UserControl.Resources>
        <system:String x:Uid="str_msgWait" x:Key="MsgWaiting">Waiting for controller ({0})...</system:String>
        <system:String x:Uid="str_msgNoCommAlarm" x:Key="MsgNoCommAlarm">Controller is not able to communicate due to alarm {0}, attempting a soft reset.</system:String>
        <system:String x:Uid="str_msgResetFailed" x:Key="MsgResetFailed">Controller soft reset failed, exiting.</system:String>
        <system:String x:Uid="str_msgEStop" x:Key="MsgEStop">E-Stop active! - clear before continuing...</system:String>
        <system:String x:Uid="str_msgEStopExit" x:Key="MsgEStopExit">E-Stop still active, exit?</system:String>
        <system:String x:Uid="str_msgHome" x:Key="MsgHome">Homing cycle required, &lt;Home&gt; to continue</system:String>
        <system:String x:Uid="str_msgDoorOpen" x:Key="MsgDoorOpen">Door is open, close door and continue?</system:String>
        <system:String x:Uid="str_msgDoorExit" x:Key="MsgDoorExit">Door is still open, exit?</system:String>
        <system:String x:Uid="str_msgDoorPersist" x:Key="MsgDoorPersist">Door state cannot be cleared with &lt;Reset&gt;</system:String>
        <system:String x:Uid="str_msgNoComm" x:Key="MsgNoComm">Controller is in {0} state and cannot respond, try a soft reset?</system:String>
        <system:String x:Uid="str_msgResetExit" x:Key="MsgResetExit">Controller soft reset failed, exiting.</system:String>
        <system:String x:Uid="str_msgNoResponse" x:Key="MsgNoResponse">Controller is not responding!</system:String>
        <cnccontrols:BoolToVisibleConverter x:Key="IsVisibleConverter" />
    </UserControl.Resources>
    <DockPanel Background="Transparent" MouseDown="outside_MouseDown" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal">
            <!-- MDI / Signals / Status moved to the fixed main-window run-control bar (Phase 2c). -->
            <TextBlock Text="{Binding Path=ParserState}" Visibility="{Binding Path=IsParserStateLive, Converter={StaticResource IsVisibleConverter}}" TextWrapping="NoWrap" Margin="5,0,0,2" HorizontalAlignment="Stretch" VerticalAlignment="Bottom"/>
        </StackPanel>
        <!-- Left sidebar / center workspace (Program-3D View-Console tabs) / right sidebar. Left and right
             columns are plain Auto (size to whichever configured panel is widest) with MinWidth floors; the
             center workspace is "*" and absorbs whatever's left. Tried draggable GridSplitters between each
             pair here instead (2026-07-23) but abandoned it: Auto+GridSplitter only behaves the way a splitter
             needs to (drag directly maps to a boundary that tracks the visible content) when the column's
             content actually stretches to fill it; jogControl/mainSlotsLeft/mainSlotsRight don't, so dragging
             just opened dead whitespace between the visible controls and the splitter instead of resizing
             anything - confirmed by direct drag testing, not just visual guesswork. Back to fixed-to-content
             Auto columns; rhGrid's own internal mainSlotsLeft/mainSlotsRight split keeps its MaxWidth=260 cap
             on the right one for the same reason it always had it - protecting the center workspace from a
             wide main-panel's own natural content width (Outline's unwrapped warning text in particular). -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <DockPanel x:Name="dp" Grid.Column="0" Margin="5,5,5,0" MinWidth="220" HorizontalAlignment="Left" VerticalAlignment="Stretch">
                <!-- Configurable region: populated from Config.LeftPanels (BuildLeftPanels). Signals/Status now
                     live in the fixed bottom run-control bar (Phase 2c). -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="t1" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                </ScrollViewer>
            </DockPanel>

            <!-- Center workspace (program list / 3D view / console) - extracted to JobWorkspace (Phase 2a).
                 Run controls (JobControl) now live in the fixed main-window bottom bar (Phase 2c). -->
            <local:JobWorkspace x:Name="workspace" Grid.Column="1"/>

            <Grid x:Name="rhGrid" Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" x:Name="joggerRow"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <cnccontrols:JogControl x:Name="jogControl" Grid.Row="0" Grid.ColumnSpan="2" Margin="5,0,0,0" MinWidth="510"/>
                <!-- Configurable main-page panels: the assigned panels flow across the two columns at runtime,
                     balanced by height (see BuildMainPanels), so they fit instead of a rigid split. Each column
                     is a ScrollViewer so an over-tall stack scrolls instead of clipping (worse at high DPI). -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="mainSlotsLeft" Margin="5,0,0,0" MinWidth="250"/>
                </ScrollViewer>
                <!-- Capped (not just MinWidth) so Feed/Spindle/Outline (the panels that consistently land here -
                     see BuildMainPanels) can't stretch wide on their own content (Outline's wrapped warning text
                     in particular) at the expense of the Program/3D View/Console workspace, which only gets
                     whatever's left over from this region. Content wraps to more lines instead - the
                     ScrollViewer already handles any resulting overflow height. -->
                <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="mainSlotsRight" Margin="0,0,0,5" MinWidth="250" MaxWidth="260"/>
                </ScrollViewer>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
