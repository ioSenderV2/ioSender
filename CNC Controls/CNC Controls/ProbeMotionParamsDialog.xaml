<Window x:Class="CNC.Controls.ProbeMotionParamsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:CNC.Controls"
        mc:Ignorable="d"
        d:DesignHeight="340" d:DesignWidth="340"
        SizeToContent="WidthAndHeight" ResizeMode="NoResize" MinWidth="340"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Title="Motion parameters" Icon="App.ico">
    <StackPanel Margin="12">
        <TextBlock x:Uid="pm_intro" TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,8"
                   Text="Probing speeds and distances. The defaults suit most setups - only change these if you know you need to."/>
        <local:NumericField x:Name="fldSearch" x:Uid="pd_searchFeed" Label="Approach speed:" ColonAt="150" Unit="mm/min" Format="#####0" ToolTip="How fast it moves to first touch the surface." Margin="0,2,0,0" Value="{Binding Path=ProbeFeedRate, Mode=TwoWay}"/>
        <local:NumericField x:Name="fldLatch" x:Uid="pd_latchFeed" Label="Re-touch speed:" ColonAt="150" Unit="mm/min" Format="#####0" ToolTip="Slow speed for the accurate second touch." Margin="0,2,0,0" Value="{Binding Path=LatchFeedRate, Mode=TwoWay}"/>
        <local:NumericField x:Name="fldRapids" x:Uid="pd_rapidsFeed" Label="Travel speed:" ColonAt="150" Unit="mm/min" Format="#####0" ToolTip="Speed for positioning moves; 0 = use the controller default." Margin="0,2,0,0" Value="{Binding Path=RapidsFeedRate, Mode=TwoWay}"/>
        <local:NumericField x:Name="fldProbeDist" x:Uid="pd_probeDist" Label="Max search distance:" ColonAt="150" Unit="mm" Format="#####0.0##" ToolTip="Furthest it will travel looking for the surface." Margin="0,2,0,0" Value="{Binding Path=ProbeDistance, Mode=TwoWay}"/>
        <local:NumericField x:Name="fldLatchDist" x:Uid="pd_latchDist" Label="Back-off distance:" ColonAt="150" Unit="mm" Format="##0.0##" ToolTip="How far it backs off before the slow second touch; 0 to skip it." Margin="0,2,0,0" Value="{Binding Path=LatchDistance, Mode=TwoWay}"/>
        <local:NumericField x:Name="fldXYClr" x:Uid="pd_xyClear" Label="Edge standoff:" ColonAt="150" Unit="mm" Format="##0.0##" ToolTip="How far out from the edge it starts before approaching." Margin="0,2,0,0" Value="{Binding Path=XYClearance, Mode=TwoWay}"/>
        <local:NumericField x:Name="fldZClr" x:Uid="pd_depth" Label="Drop to side:" ColonAt="150" Unit="mm" Format="##0.0##" ToolTip="How far it lowers to get beside the edge before probing sideways." Margin="0,2,0,0" Value="{Binding Path=Depth, Mode=TwoWay}"/>
        <local:NumericField x:Name="fldOffsetX" x:Uid="pd_offsetX" Label="Spindle offset X:" ColonAt="150" Unit="mm" Format="-##0.0##" ToolTip="Probe tip distance from the spindle centre (0 for a centred 3D probe)." Margin="0,2,0,0" Value="{Binding Path=ProbeOffsetX, Mode=TwoWay}"/>
        <local:NumericField x:Name="fldOffsetY" x:Uid="pd_offsetY" Label="Spindle offset Y:" ColonAt="150" Unit="mm" Format="-##0.0##" ToolTip="Probe tip distance from the spindle centre (0 for a centred 3D probe)." Margin="0,2,0,0" Value="{Binding Path=ProbeOffsetY, Mode=TwoWay}"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Uid="pm_close" x:Name="btnClose" Content="Close" IsDefault="True" IsCancel="True" MinWidth="80" MinHeight="24" Click="btnClose_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
