<UserControl x:Class="CNC.Controls.OffsetFlyout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CNC.Controls"
             mc:Ignorable="d"
             d:DesignHeight="30" d:DesignWidth="200" Width="200">
    <UserControl.Resources>
        <Style x:Key="FlyoutGlyphButton" TargetType="ButtonBase">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ButtonBase">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33000000"/>
                            </Trigger>
                            <Trigger Property="ToggleButton.IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#553F7FBF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border BorderBrush="DarkGray" BorderThickness="1" Background="#FFE5E5EA" Padding="4,10">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Button x:Name="btnGo" MinWidth="46" Height="22" Padding="6,0" Click="btnGo_Click" ToolTip="Go to offset"/>
            <Button x:Name="btnSet" Content="Set" Height="22" Padding="6,0" Margin="3,0,0,0" Click="btnSet_Click" Visibility="Collapsed" ToolTip="Store current machine position in this offset"/>
            <ToggleButton x:Name="btnPin" Content="📌" FontSize="11" Width="17" Height="17" Margin="4,0,0,0" Style="{StaticResource FlyoutGlyphButton}"
                          ToolTip="Pin (keep open when another flyout is opened)" Checked="btnPin_Changed" Unchecked="btnPin_Changed"/>
            <Button x:Name="btnClose" Content="✕" FontSize="10" Width="15" Height="17" Style="{StaticResource FlyoutGlyphButton}" ToolTip="Close" Click="btn_Close"/>
        </StackPanel>
    </Border>
</UserControl>
