<UserControl x:Class="CNC.Controls.JogPadControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CNC.Controls"
             mc:Ignorable="d"
             d:DesignHeight="60" d:DesignWidth="110">
    <UserControl.Resources>
        <Style x:Key="JogPadBtn" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    <!-- Small X/Y/Z jog pad: one discrete step at the currently selected UI-jog distance/feed (Settings:App /
         the UI Jogging panel). Buttons are disabled/ignored unless the controller can jog. -->
    <Grid HorizontalAlignment="Left" VerticalAlignment="Center">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Column="0" Grid.Row="0" Text="X" HorizontalAlignment="Center" FontSize="10" Foreground="#FF57606A"/>
        <TextBlock Grid.Column="1" Grid.Row="0" Text="Y" HorizontalAlignment="Center" FontSize="10" Foreground="#FF57606A"/>
        <TextBlock Grid.Column="2" Grid.Row="0" Text="Z" HorizontalAlignment="Center" FontSize="10" Foreground="#FF57606A"/>

        <Button Grid.Column="0" Grid.Row="1" Tag="X+" Content="+" Style="{StaticResource JogPadBtn}" Click="Jog_Click" ToolTip="Jog X+ one step"/>
        <Button Grid.Column="1" Grid.Row="1" Tag="Y+" Content="+" Style="{StaticResource JogPadBtn}" Click="Jog_Click" ToolTip="Jog Y+ one step"/>
        <Button Grid.Column="2" Grid.Row="1" Tag="Z+" Content="+" Style="{StaticResource JogPadBtn}" Click="Jog_Click" ToolTip="Jog Z+ one step"/>

        <Button Grid.Column="0" Grid.Row="2" Tag="X-" Content="&#8211;" Style="{StaticResource JogPadBtn}" Click="Jog_Click" ToolTip="Jog X- one step"/>
        <Button Grid.Column="1" Grid.Row="2" Tag="Y-" Content="&#8211;" Style="{StaticResource JogPadBtn}" Click="Jog_Click" ToolTip="Jog Y- one step"/>
        <Button Grid.Column="2" Grid.Row="2" Tag="Z-" Content="&#8211;" Style="{StaticResource JogPadBtn}" Click="Jog_Click" ToolTip="Jog Z- one step"/>
    </Grid>
</UserControl>
