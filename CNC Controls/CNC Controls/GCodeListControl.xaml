<UserControl x:Class="CNC.Controls.GCodeListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CNC.Controls"
             mc:Ignorable="d"
             d:DesignHeight="335" d:DesignWidth="400"
             Loaded="UserControl_Loaded">
    <!-- Light mint background marks this as the program view connected to the streamer (the loaded job);
         tool previews use the plain raw-text box, so mint = "this is what Cycle Start will run". -->
    <DataGrid x:Name="grdGCode" Grid.Row="0" ItemsSource="{Binding}" Background="#FFE4F6E6" RowBackground="#FFE4F6E6" AllowDrop="True" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" AutoGenerateColumns="False"
              CanUserSortColumns="false" CanUserResizeRows="False" IsReadOnly="true" SelectionChanged="grdGCode_SelectionChanged"
              EnableRowVirtualization="True" ScrollViewer.CanContentScroll="True"
              VirtualizingPanel.IsVirtualizingWhenGrouping="True" VirtualizingPanel.VirtualizationMode="Recycling" VirtualizingPanel.ScrollUnit="Item"
              DragEnter="grdGCode_Drag" DragOver="grdGCode_Drag" DragLeave="grdGCode_Drag" Drop="grdGCode_Drop">
        <!-- Highlight the currently-executing line in green. The streamer marks it Sent="@" from the
             controller's reported line number (needs line-number reporting); completed lines show "ok". -->
        <DataGrid.RowStyle>
            <Style TargetType="DataGridRow">
                <Style.Triggers>
                    <DataTrigger Binding="{Binding Sent}" Value="@">
                        <Setter Property="Background" Value="#FF4CAF50"/>
                        <Setter Property="Foreground" Value="White"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </DataGrid.RowStyle>
        <DataGrid.Columns>
            <DataGridTextColumn x:Uid="hdr_block" Header="Block" Binding="{Binding LineNum}" Width="60" MinWidth="60" MaxWidth="70"/>
            <DataGridTextColumn Header="" Binding="{Binding Sent}" Width="*" MinWidth="30" MaxWidth="60"/>
            <DataGridTextColumn x:Uid="hdr_data" Header="Data" Binding="{Binding Data}" Width="*" MinWidth="280"/>
        </DataGrid.Columns>
        <DataGrid.ContextMenu>
            <ContextMenu x:Name="ctxMenu">
                <MenuItem x:Uid="mnu_sendToController" Header="Send to controller" IsEnabled="{Binding Path=MultipleSelected}" Click="SendController_Click" />
                <MenuItem x:Uid="mnu_startFromHere" Header="Start from here" IsEnabled="{Binding Path=SingleSelected}" Click="StartHere_Click" />
                <MenuItem x:Uid="mnu_copyToMDI" Header="Copy to MDI" IsEnabled="{Binding Path=SingleSelected}" Click="CopyMDI_Click" />
				<MenuItem x:Uid="mnu_ToggleBreak" Header="Toggle Break" IsEnabled="{Binding Path=SingleSelected}" Click="ToggleBreak_Click" />
			</ContextMenu>
        </DataGrid.ContextMenu>
        <DataGrid.GroupStyle>
            <!-- Toolpath outline: collapsible per-section groups, shown only when a folder is loaded
                 (see GCode.LoadFolder; a single-file load adds no group descriptions so this is inert). -->
            <GroupStyle>
                <GroupStyle.ContainerStyle>
                    <Style TargetType="{x:Type GroupItem}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type GroupItem}">
                                    <!-- Groups default collapsed so the whole toolpath outline is visible after a
                                         folder load; expand individually via the chevron. -->
                                    <Expander IsExpanded="False" Background="#FFEFEFEF" BorderBrush="#FFCCCCCC" BorderThickness="0,0,0,1">
                                        <Expander.Header>
                                            <!-- Context menu lives on the header only (not the Expander) so gcode-line
                                                 right-clicks fall through to the DataGrid's line menu. -->
                                            <DockPanel HorizontalAlignment="Stretch" Background="Transparent">
                                                <DockPanel.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem x:Uid="mnu_startFromToolpath" Header="Start from this toolpath" Click="StartSection_Click"/>
                                                        <MenuItem x:Uid="mnu_runOneToolpath" Header="Run just this toolpath" Click="RunSection_Click"/>
                                                    </ContextMenu>
                                                </DockPanel.ContextMenu>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Margin="2,0,0,0"/>
                                                <TextBlock Text="{Binding ItemCount, StringFormat=' ({0} lines)'}" Foreground="Gray" Margin="4,0,0,0"/>
                                            </DockPanel>
                                        </Expander.Header>
                                        <ItemsPresenter/>
                                    </Expander>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </GroupStyle.ContainerStyle>
            </GroupStyle>
        </DataGrid.GroupStyle>
    </DataGrid>
</UserControl>
