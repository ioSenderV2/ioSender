<Window x:Class="CNC.Controls.ProbeDefinitionEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:CNC.Controls"
        mc:Ignorable="d"
        d:DesignHeight="260" d:DesignWidth="340"
        SizeToContent="WidthAndHeight" ResizeMode="NoResize" MinWidth="340"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Title="Probe definition" Icon="App.ico">
    <StackPanel Margin="12">
        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
            <Label x:Uid="pd_type" Content="Type:" Width="120" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
            <ComboBox x:Name="cbxType" Width="170" MinHeight="22" VerticalAlignment="Center" SelectionChanged="cbxType_SelectionChanged">
                <ComboBoxItem x:Uid="pd_type3d" Content="3D touch probe" Tag="ThreeDProbe"/>
                <ComboBoxItem x:Uid="pd_typePlate" Content="Touch plate" Tag="TouchPlate"/>
                <ComboBoxItem x:Uid="pd_typeSetter" Content="Tool setter" Tag="ToolSetter"/>
                <ComboBoxItem x:Uid="pd_typeEdge" Content="Edge finder" Tag="EdgeFinder"/>
            </ComboBox>
        </StackPanel>
        <Separator Margin="0,7"/>
        <!-- Essentials only - the speeds/distances live behind 'Edit motion params'. Visibility + the diameter
             label are set per type in code-behind. -->
        <local:NumericField x:Name="fldDiameter" x:Uid="pd_diameter" Label="Tip diameter:" ColonAt="120" Unit="mm" Format="##0.0##" ToolTip="Diameter of the probe tip (3D / edge finder) or the bit in the collet (touch plate)." Margin="0,2,0,0" Value="{Binding Path=ProbeDiameter, Mode=TwoWay}"/>
        <local:NumericField x:Name="fldBody" x:Uid="pd_body" Label="Ball diameter:" ColonAt="120" Unit="mm" Format="###0.0##" ToolTip="3D probe ball/body diameter; its radius is the minimum standoff kept clear of the work on rapid/G28 moves and the Load Stock approach clearance." Margin="0,2,0,0" Value="{Binding Path=BodyDiameter, Mode=TwoWay}"/>
        <local:NumericField x:Name="fldPlate" x:Uid="pd_plate" Label="Plate thickness:" ColonAt="120" Unit="mm" Format="##0.0##" ToolTip="Plate height - work Z0 is the plate top minus this." Margin="0,2,0,0" Value="{Binding Path=PlateThickness, Mode=TwoWay}"/>
        <local:NumericField x:Name="fldLip" x:Uid="pd_lip" Label="Lip width:" ColonAt="120" Unit="mm" Format="##0.0##" ToolTip="How far the plate's edge sticks out past the stock corner." Margin="0,2,0,0" Value="{Binding Path=LipWidth, Mode=TwoWay}"/>
        <local:NumericField x:Name="fldSetter" x:Uid="pd_setter" Label="Setter height:" ColonAt="120" Unit="mm" Format="-###0.0##" ToolTip="Trigger height of the tool setter." Margin="0,2,0,0" Value="{Binding Path=SetterHeight, Mode=TwoWay}"/>
        <local:NumericField x:Name="fldSpin" x:Uid="pd_spin" Label="Spin speed:" ColonAt="120" Unit="RPM" Format="#####0" ToolTip="Spinning edge-finder speed; 0 = does not spin." Margin="0,2,0,0" Value="{Binding Path=SpinRPM, Mode=TwoWay}"/>
        <DockPanel Margin="0,14,0,0">
            <Button x:Uid="pd_motion" x:Name="btnMotion" Content="Edit motion params…" DockPanel.Dock="Left" Padding="10,2" MinHeight="24" Click="btnMotion_Click"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Uid="pd_ok" x:Name="btnOk" Content="OK" Click="btnOk_Click" Width="75" MinHeight="24" IsDefault="True"/>
                <Button x:Uid="pd_cancel" x:Name="btnCancel" Content="Cancel" IsCancel="True" Width="75" MinHeight="24" Margin="6,0,0,0"/>
            </StackPanel>
        </DockPanel>
    </StackPanel>
</Window>
