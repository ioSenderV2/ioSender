<Window x:Class="CNC.Controls.PendingChangesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:CNC.Controls"
        mc:Ignorable="d"
        d:DesignHeight="320" d:DesignWidth="560"
        SizeToContent="Height" Width="580" MaxHeight="520" ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Title="Pending changes" Icon="App.ico">
    <DockPanel Margin="10">
        <StackPanel x:Name="panelClose" DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Uid="pc_close" Content="Close" IsCancel="True" Width="80" MinHeight="24" Click="btnClose_Click"/>
        </StackPanel>
        <StackPanel x:Name="panelConfirm" DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Visibility="Collapsed">
            <Button x:Uid="pc_ok" x:Name="btnOk" Content="Restore settings" IsDefault="True" Width="110" MinHeight="24" Click="btnOk_Click"/>
            <Button x:Uid="pc_cancel" Content="Cancel" IsCancel="True" Width="80" MinHeight="24" Margin="6,0,0,0"/>
        </StackPanel>
        <DataGrid x:Uid="grd" x:Name="grd" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                  CanUserAddRows="False" CanUserDeleteRows="False" MaxHeight="420" GridLinesVisibility="All">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Status}" Value="Applied">
                            <Setter Property="Background" Value="#FFDCF5DC"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                            <Setter Property="Background" Value="#FFF6D3D3"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="RolledBack">
                            <Setter Property="Background" Value="#FFF7E7C6"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="NotSupported">
                            <Setter Property="Background" Value="#FFE8E8E8"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn x:Uid="pc_setting" Header="Setting" Binding="{Binding Setting}" MinWidth="80"/>
                <DataGridTextColumn x:Uid="pc_name" Header="Name" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn x:Uid="pc_current" Header="Current" Binding="{Binding OldValue}" MinWidth="120"/>
                <DataGridTextColumn x:Uid="pc_new" Header="New" Binding="{Binding NewValue}" MinWidth="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
