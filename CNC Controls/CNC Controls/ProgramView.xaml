<UserControl x:Class="CNC.Controls.ProgramView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CNC.Controls"
             mc:Ignorable="d" d:DesignHeight="335" d:DesignWidth="400">
    <!-- Standalone, streamer-connectable program view: a titled host around the shared GCodeListControl.
         Owns its own G-code (Blocks) and can be Connect()'d to the streamer - see ProgramView.xaml.cs.
         One instance per Load File / Load Folder / wizard Generate; the connected one (stack top) runs. -->
    <DockPanel>
        <Border x:Name="titleBar" DockPanel.Dock="Top" Background="#FFEFEFEF" BorderBrush="#FFCCCCCC"
                BorderThickness="0,0,0,1" Padding="6,3" Visibility="Collapsed">
            <TextBlock x:Name="txtTitle" FontWeight="SemiBold"/>
        </Border>
        <local:GCodeListControl x:Name="gcodeList"/>
    </DockPanel>
</UserControl>
