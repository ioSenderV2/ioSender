<UserControl x:Class="CNC.Controls.ProgramView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CNC.Controls"
             mc:Ignorable="d" d:DesignHeight="335" d:DesignWidth="400">
    <!-- Standalone, streamer-connectable program view: a titled host around the shared GCodeListControl.
         Owns its own G-code (Blocks) and can be Connect()'d to the streamer - see ProgramView.xaml.cs.
         One instance per Load File / Load Folder / wizard Generate; the connected one (stack top) runs. -->
    <DockPanel>
        <!-- Click anywhere on the title bar to toggle between the full program and the compact 3-line run view
             (previous / current / next line). Cursor + hint make it discoverable. -->
        <Border x:Name="titleBar" DockPanel.Dock="Top" Background="#FFEFEFEF" BorderBrush="#FFCCCCCC"
                BorderThickness="0,0,0,1" Padding="6,3" Visibility="Collapsed" Cursor="Hand"
                MouseLeftButtonUp="TitleBar_Click" ToolTip="Click to collapse to a 3-line run view / expand">
            <DockPanel>
                <TextBlock x:Name="txtTitleHint" DockPanel.Dock="Right" Foreground="#FF888888" FontSize="11"
                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                <TextBlock x:Name="txtTitle" FontWeight="SemiBold"/>
            </DockPanel>
        </Border>
        <local:GCodeListControl x:Name="gcodeList"/>
    </DockPanel>
</UserControl>
