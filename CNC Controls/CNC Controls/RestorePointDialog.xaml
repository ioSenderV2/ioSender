<Window x:Class="CNC.Controls.RestorePointDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:CNC.Controls"
        mc:Ignorable="d"
        d:DesignHeight="380" d:DesignWidth="540"
        x:Uid="wnd_restorePoint" Title="Restore settings" Height="380" Width="540" MinWidth="420" MinHeight="260"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Icon="App.ico">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Uid="txt_restoreIntro" Grid.Row="0" Text="Select a restore point (most recent first), or browse for a backup file:" Margin="0,0,0,6" TextWrapping="Wrap"/>
        <DataGrid x:Name="dgrSnapshots" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single" SelectionUnit="FullRow" HeadersVisibility="Column"
                  CanUserReorderColumns="False" CanUserResizeRows="False" CanUserAddRows="False"
                  CanUserSortColumns="True" GridLinesVisibility="Horizontal"
                  MouseDoubleClick="dgrSnapshots_MouseDoubleClick">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="ToolTip" Value="{Binding Tooltip}"/>
                    <Setter Property="ToolTipService.ShowDuration" Value="60000"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn x:Uid="col_rpSaved" Header="Saved" Binding="{Binding SavedText}" Width="150"/>
                <DataGridTextColumn x:Uid="col_rpChanges" Header="Changes" Binding="{Binding ChangesText}" Width="70"/>
                <DataGridTextColumn x:Uid="col_rpMachine" Header="Machine" Binding="{Binding Machine}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnBrowse" x:Uid="btn_rpBrowse" Content="Browse..." Width="90" Margin="0,0,8,0" Click="btnBrowse_Click"/>
            <Button x:Name="btnRestore" x:Uid="btn_rpRestore" Content="Restore" Width="90" Margin="0,0,8,0" IsDefault="True" Click="btnRestore_Click"/>
            <Button x:Name="btnCancel" x:Uid="btn_rpCancel" Content="Cancel" Width="90" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
