<UserControl x:Class="CNC.Controls.JogBaseControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:CNC.Controls"
             xmlns:core="clr-namespace:CNC.Core;assembly=CNC.Core"
             mc:Ignorable="d"
             FocusVisualStyle="{x:Null}"
             Loaded="JogControl_Loaded"
             d:DesignHeight="248" Width="Auto">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="SharedStyles.xaml"/>
                <ResourceDictionary>
                    <!-- Jogging & motion functional color (style guide v0.1): rest state is the category's
                         "very light" fill with the bold base as ink text; the shared Button template's
                         hover/press overlay darkens this correctly without needing a separate pressed brush. -->
                    <Style x:Key="JogButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Width" Value="60"/>
                        <Setter Property="Height" Value="60"/>
                        <Setter Property="Focusable" Value="False"/>
                        <Setter Property="Content" Value="xx"/>
                        <Setter Property="Background" Value="{StaticResource JogFillBrush}"/>
                        <Setter Property="BorderBrush" Value="{StaticResource JogFillBrush}"/>
                        <Setter Property="Foreground" Value="{StaticResource JogBaseBrush}"/>
                    </Style>
                </ResourceDictionary>
                <ResourceDictionary>
                    <local:EnumValueToBooleanConverter x:Key="EnumToCheckedConverter" />
                    <local:BoolToVisibleConverter x:Key="IsVisibleConverter" />
                    <local:LogicalNotConverter x:Key="IsNotVisibleConverter">
                        <local:LogicalNotConverter.FinalConverter>
                            <local:BoolToVisibleConverter />
                        </local:LogicalNotConverter.FinalConverter>
                    </local:LogicalNotConverter>
                    <local:LogicalNotConverter x:Key="LogicalNotConverter" />
                    <local:LogicalOrConverter x:Key="LogicalOrConverter"/>
                    <local:GrblStateToIsJoggingConverter x:Key ="IsJoggingConverter"/>
                    <local:AxisLetterToJogPlusConverter x:Key="JogPlusConverter"/>
                    <local:AxisLetterToJogMinusConverter x:Key="JogMinusConverter"/>
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid>
        <Grid.IsEnabled>
            <MultiBinding Converter="{StaticResource LogicalOrConverter}">
                <Binding Path="IsJobRunning" Converter="{StaticResource LogicalNotConverter}"/>
                <Binding Path="GrblState" Converter="{StaticResource IsJoggingConverter}"/>
            </MultiBinding>
        </Grid.IsEnabled>
        <StackPanel x:Name="selectorPanel">
            <GroupBox x:Uid="grp_jogDistance" Header="Distance" HorizontalAlignment="Left" Margin="5,0,0,0" VerticalAlignment="Top" MinWidth="105">
                <StackPanel>
                    <RadioButton Tag="3" Content="{Binding Path=JogData.Distance3, RelativeSource={RelativeSource AncestorType=UserControl}}" IsChecked="{Binding Path=JogData.StepSize, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource EnumToCheckedConverter}, ConverterParameter=Step3}" HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Click="distance_Click"/>
                    <RadioButton Tag="2" Content="{Binding Path=JogData.Distance2, RelativeSource={RelativeSource AncestorType=UserControl}}" IsChecked="{Binding Path=JogData.StepSize, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource EnumToCheckedConverter}, ConverterParameter=Step2}" HorizontalAlignment="Left" Margin="10,3,0,0" VerticalAlignment="Top" Click="distance_Click"/>
                    <RadioButton Tag="1" Content="{Binding Path=JogData.Distance1, RelativeSource={RelativeSource AncestorType=UserControl}}" IsChecked="{Binding Path=JogData.StepSize, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource EnumToCheckedConverter}, ConverterParameter=Step1}" HorizontalAlignment="Left" Margin="10,3,0,0" VerticalAlignment="Top" Click="distance_Click"/>
                    <RadioButton Tag="0" Content="{Binding Path=JogData.Distance0, RelativeSource={RelativeSource AncestorType=UserControl}}" IsChecked="{Binding Path=JogData.StepSize, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource EnumToCheckedConverter}, ConverterParameter=Step0}" HorizontalAlignment="Left" Margin="10,3,0,0" VerticalAlignment="Top" Click="distance_Click"/>
                    <RadioButton Tag="4" x:Uid="lbl_jogContinuous" Content="Continuous" IsChecked="{Binding Path=JogData.StepSize, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource EnumToCheckedConverter}, ConverterParameter=Continuous}" HorizontalAlignment="Left" Margin="10,3,0,0" VerticalAlignment="Top" Click="distance_Click"/>
                    <Label Content="{Binding Path=Unit}" FontSize="8"/>
                </StackPanel>
            </GroupBox>
            <GroupBox x:Uid="grp_jogFeedrate" Header="Feed rate" HorizontalAlignment="Left" Margin="5,0,0,4" VerticalAlignment="Top" MinWidth="105">
                <StackPanel>
                    <RadioButton Tag="3" Content="{Binding Path=JogData.Feedrate3, RelativeSource={RelativeSource AncestorType=UserControl}}" IsChecked="{Binding Path=JogData.Feed, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource EnumToCheckedConverter}, ConverterParameter=Feed3}"  HorizontalAlignment="Left" Margin="10,5,0,0" VerticalAlignment="Top" Click="feedrate_Click"/>
                    <RadioButton Tag="2" Content="{Binding Path=JogData.Feedrate2, RelativeSource={RelativeSource AncestorType=UserControl}}" IsChecked="{Binding Path=JogData.Feed, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource EnumToCheckedConverter}, ConverterParameter=Feed2}" HorizontalAlignment="Left" Margin="10,3,0,0" VerticalAlignment="Top" Click="feedrate_Click"/>
                    <RadioButton Tag="1" Content="{Binding Path=JogData.Feedrate1, RelativeSource={RelativeSource AncestorType=UserControl}}" IsChecked="{Binding Path=JogData.Feed, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource EnumToCheckedConverter}, ConverterParameter=Feed1}" HorizontalAlignment="Left" Margin="10,3,0,0" VerticalAlignment="Top" Click="feedrate_Click"/>
                    <RadioButton Tag="0" Content="{Binding Path=JogData.Feedrate0, RelativeSource={RelativeSource AncestorType=UserControl}}" IsChecked="{Binding Path=JogData.Feed, Mode=TwoWay, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource EnumToCheckedConverter}, ConverterParameter=Feed0}" HorizontalAlignment="Left" Margin="10,3,0,0" VerticalAlignment="Top" Click="feedrate_Click"/>
                    <Label Content="{Binding Path=FeedrateUnit}" FontSize="8"/>
                </StackPanel>
            </GroupBox>
        </StackPanel>
        <StackPanel x:Name="arrowPanel" Orientation="Horizontal" Margin="115,10,5,0" Width="Auto" Height="Auto">
            <StackPanel Orientation="Horizontal" Width="Auto" Height="Auto" Visibility="{Binding Path=LatheModeEnabled, Converter={StaticResource IsNotVisibleConverter}}">
                <StackPanel VerticalAlignment="Center">
                    <local:JogButton Content="X-" Style="{StaticResource JogButtonStyle}" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Center" Margin="5,0">
                    <local:JogButton Content="Y+" Style="{StaticResource JogButtonStyle}" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
                    <!-- Centre button: bullseye = "go to centre at safe Z" when idle; red stop sign = "stop jog" while
                         jogging. Icon + tooltip swap off GrblState via IsJoggingConverter (no code-behind needed). -->
                    <Button x:Uid="btn_jogCenter" Margin="0,5" Click="CenterButton_Click" ToolTip="Go to centre at safe Z">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource JogButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GrblState, Converter={StaticResource IsJoggingConverter}}" Value="True">
                                        <Setter Property="ToolTip" Value="Stop jog"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Grid>
                            <!-- Stop sign kept in the tree but intentionally hidden: panel/keyboard jogs are
                                 momentary (they stop the instant the button/key is released), so flashing a stop
                                 affordance here would be misleading. The button still cancels an in-progress move
                                 when clicked; the blank face during a jog is the honest state. -->
                            <Viewbox Width="34" Height="34" Visibility="Collapsed">
                                <Grid Width="100" Height="100">
                                    <Polygon Points="30,2 70,2 98,30 98,70 70,98 30,98 2,70 2,30" Fill="#FFD32F2F" Stroke="#FFB71C1C" StrokeThickness="4" StrokeLineJoin="Round"/>
                                </Grid>
                            </Viewbox>
                            <Viewbox Width="34" Height="34">
                                <Viewbox.Style>
                                    <Style TargetType="Viewbox">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding GrblState, Converter={StaticResource IsJoggingConverter}}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Viewbox.Style>
                                <Grid Width="100" Height="100">
                                    <Ellipse Width="98" Height="98" Fill="#FFD32F2F"/>
                                    <Ellipse Width="64" Height="64" Fill="White"/>
                                    <Ellipse Width="30" Height="30" Fill="#FFD32F2F"/>
                                </Grid>
                            </Viewbox>
                        </Grid>
                    </Button>
                    <local:JogButton Content="Y-" Style="{StaticResource JogButtonStyle}" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Center">
                    <local:JogButton Content="X+" Style="{StaticResource JogButtonStyle}" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
                </StackPanel>
                <StackPanel Style="{StaticResource ZAxisVisibleStyle}" VerticalAlignment="Center" Margin="5,0,0,0">
                    <local:JogButton Content="Z+" Style="{StaticResource JogButtonStyle}" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
                    <local:JogButton Content="Z-" Style="{StaticResource JogButtonStyle}" Margin="0,70,0,0" VerticalAlignment="Top" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Width="Auto" Height="Auto" Visibility="{Binding Path=LatheModeEnabled, Converter={StaticResource IsVisibleConverter}}">
                <StackPanel VerticalAlignment="Center">
                    <local:JogButton Content="Z-" Style="{StaticResource JogButtonStyle}" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Center" Margin="5,0">
                    <local:JogButton Content="X-" Style="{StaticResource JogButtonStyle}" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
                    <Button Tag="stop" Style="{StaticResource JogButtonStyle}" Margin="0,5" Click="Button_Click">
                        <Button.Content>
                            <Image Source="Resources/Symbols_Stop_32xLG.png"/>
                        </Button.Content>
                    </Button>
                    <local:JogButton Content="X+" Style="{StaticResource JogButtonStyle}" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Center">
                    <local:JogButton Content="Z+" Style="{StaticResource JogButtonStyle}" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
                </StackPanel>
                <StackPanel Style="{StaticResource YAxisVisibleStyle}" VerticalAlignment="Center" Margin="5,0,0,0">
                    <local:JogButton Content="Y+" Style="{StaticResource JogButtonStyle}" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
                    <local:JogButton Content="Y-" Style="{StaticResource JogButtonStyle}" Margin="0,70,0,0" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
                </StackPanel>
            </StackPanel>
            <StackPanel Style="{StaticResource AAxisVisibleStyle}" VerticalAlignment="Center" Margin="5,0,0,0">
                <local:JogButton Content="{Binding Path=AxisLetter.A, Converter={StaticResource JogPlusConverter}, Mode=OneWay}" Style="{StaticResource JogButtonStyle}" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
                <local:JogButton Content="{Binding Path=AxisLetter.A, Converter={StaticResource JogMinusConverter}, Mode=OneWay}" Style="{StaticResource JogButtonStyle}" Margin="0,70,0,0" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
            </StackPanel>
            <StackPanel Style="{StaticResource BAxisVisibleStyle}" VerticalAlignment="Center" Margin="5,0,0,0">
                <local:JogButton Content="{Binding Path=AxisLetter.B, Converter={StaticResource JogPlusConverter}, Mode=OneWay}" Style="{StaticResource JogButtonStyle}" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
                <local:JogButton Content="{Binding Path=AxisLetter.B, Converter={StaticResource JogMinusConverter}, Mode=OneWay}" Style="{StaticResource JogButtonStyle}" Margin="0,70,0,0" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
            </StackPanel>
            <StackPanel Style="{StaticResource CAxisVisibleStyle}" VerticalAlignment="Center" Margin="5,0,0,0">
                <local:JogButton Content="{Binding Path=AxisLetter.C, Converter={StaticResource JogPlusConverter}, Mode=OneWay}" Style="{StaticResource JogButtonStyle}" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
                <local:JogButton Content="{Binding Path=AxisLetter.C, Converter={StaticResource JogMinusConverter}, Mode=OneWay}" Style="{StaticResource JogButtonStyle}" Margin="0,70,0,0" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
            </StackPanel>
            <StackPanel Style="{StaticResource UAxisVisibleStyle}" VerticalAlignment="Center" Margin="5,0,0,0">
                <local:JogButton Content="U+" Style="{StaticResource JogButtonStyle}" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
                <local:JogButton Content="U-" Style="{StaticResource JogButtonStyle}" Margin="0,70,0,0" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
            </StackPanel>
            <StackPanel Style="{StaticResource VAxisVisibleStyle}" VerticalAlignment="Center" Margin="5,0,0,0">
                <local:JogButton Content="V+" Style="{StaticResource JogButtonStyle}" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
                <local:JogButton Content="V-" Style="{StaticResource JogButtonStyle}" Margin="0,70,0,0" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
            </StackPanel>
            <StackPanel Style="{StaticResource WAxisVisibleStyle}" VerticalAlignment="Center" Margin="5,0,0,0">
                <local:JogButton Content="W+" Style="{StaticResource JogButtonStyle}" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
                <local:JogButton Content="W-" Style="{StaticResource JogButtonStyle}" Margin="0,70,0,0" JogStart="JogButton_JogStart" JogEnd="JogButton_JogEnd"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
