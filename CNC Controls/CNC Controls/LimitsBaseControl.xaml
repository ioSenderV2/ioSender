<UserControl x:Class="CNC.Controls.LimitsBaseControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CNC.Controls"
             mc:Ignorable="d"
             d:DesignHeight="26" d:DesignWidth="120">
    <!-- Compact "X: [0 .. 860) mm" single-line range display, replacing the old two-NumericField
         "0.000  -  860.000 mm" layout. A NumericField (even read-only, unit hidden) still carries its own
         fixed-width text box chrome sized to fit worst-case digit count - two of those side by side was the
         actual source of the wasted width, not just the duplicated decimals. This is one plain TextBlock;
         all the number formatting/unit conversion happens in code-behind (UpdateDisplay) instead of relying
         on NumericField's built-in mm/in conversion - see UnitToggleMenu.cs, extended to recognize this
         control directly (it used to find its state by enumerating NumericField descendants). -->
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
        <Label x:Name="axis" MinWidth="18" Padding="5,0,0,0" HorizontalContentAlignment="Right" Content="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}"/>
        <Label Content=":" Padding="0,0,4,0"/>
        <TextBlock x:Name="range" VerticalAlignment="Center" Text="[0 .. 0] mm"/>
    </StackPanel>
</UserControl>
