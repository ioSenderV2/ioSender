<Window x:Class="CNC.Controls.PortDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CNC.Controls"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        x:Uid="dlg_connection"
        Title="Sender connection" SizeToContent="WidthAndHeight" MinHeight="240" MinWidth="450" Icon="App.ico" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="PortErrorStyle" TargetType="local:NumericTextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="Green" />
                    <Setter Property="ToolTip" Value="{Binding RelativeSource={x:Static RelativeSource.Self},
                        Path=(Validation.Errors)[0].ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Ip4ErrorStyle" TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="true">
                    <Setter Property="TextBox.ToolTip">
                        <Setter.Value>
                            <Binding RelativeSource="{RelativeSource Self}" Path="(Validation.Errors)[0].ErrorContent" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="HostErrorStyle" TargetType="ComboBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="true">
                    <Setter Property="ToolTip">
                        <Setter.Value>
                            <Binding RelativeSource="{RelativeSource Self}" Path="(Validation.Errors)[0].ErrorContent" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TabControl x:Name="tab" Grid.Row="0" Margin="5,5,5,0">
            <TabItem x:Uid="tab_serial" x:Name="tabSerial" Header="Serial">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <Label x:Uid="lbl_serialPort" Content="Port:" HorizontalAlignment="Left" HorizontalContentAlignment="Right" Width="80" VerticalAlignment="Center"/>
                        <ComboBox HorizontalAlignment="Left" VerticalAlignment="Center" Width="285"
                            DropDownOpened="CbxPorts_DropDownOpened"
                            ItemsSource="{Binding Path=Com.Ports}"
                            SelectedValue="{Binding Path=Com.SelectedPort, Mode=TwoWay}"
                            DisplayMemberPath="FullName"
                            SelectedValuePath="Name" 
                         />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Label x:Uid="lbl_serialBaud" Content="Baud rate:" HorizontalAlignment="Left" HorizontalContentAlignment="Right" Width="80" VerticalAlignment="Center"/>
                        <ComboBox HorizontalAlignment="Left" VerticalAlignment="Center" Width="90"
                            ItemsSource="{Binding Path=Com.Baud}"
                            SelectedValue="{Binding Path=Com.SelectedBaud, Mode=TwoWay}"
                         />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,4,0,0">
                        <Label x:Uid="lbl_onConnect" Content="On connect:" HorizontalAlignment="Left" HorizontalContentAlignment="Right" Width="80" VerticalAlignment="Center"/>
                        <ComboBox HorizontalAlignment="Left" VerticalAlignment="Center" Width="90"
                            ItemsSource="{Binding Path=Com.ConnectModes}"
                            SelectedItem="{Binding Path=Com.SelectedMode, Mode=TwoWay}"
                            DisplayMemberPath="Name"
                            SelectedValuePath="Mode"
                        />
                    </StackPanel>
                </StackPanel>
            </TabItem>
            <TabItem x:Uid="tab_network" x:Name="tabNetwork" Header="Network">
                <StackPanel>
                    <CheckBox x:Uid="lbl_websocket" Content="WebSocket" IsChecked="{Binding Path=IsWebSocket, Mode=TwoWay}" Margin="80,5,0,0"
                              ToolTip="Connect over WebSocket instead of a plain TCP socket - use this only if your controller's network stack requires it (most grblHAL network builds use plain TCP)."/>
                    <StackPanel Orientation="Horizontal" Margin="0,5">
                        <Label x:Uid="lbl_netPort" Content="Port:" HorizontalAlignment="Left" HorizontalContentAlignment="Right" Width="80"/>
                        <local:NumericTextBox x:Uid="fld_netPort" Style="{StaticResource PortErrorStyle}" Width="120" Format="####0"
                                              ToolTip="TCP/WebSocket port to connect to. Must match the port configured in the controller's network settings.">
                            <local:NumericTextBox.Value>
                                <Binding Path="NetPort" Mode="TwoWay" ValidatesOnNotifyDataErrors="True" ValidatesOnDataErrors="True" NotifyOnValidationError="True" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <local:NumericRangeRule Min="0" Max="65535" ValidatesOnTargetUpdated="True" />
                                    </Binding.ValidationRules>
                                </Binding>
                            </local:NumericTextBox.Value>
                        </local:NumericTextBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                        <Label x:Uid="lbl_ipAddress" Content="IP address:" HorizontalAlignment="Left" HorizontalContentAlignment="Right" Width="80"/>
                        <!-- Editable host combo: type an IP/hostname, or pick one that Scan network discovered.
                             The dropdown shows the rich "host:port - grblHAL x.x" label (ItemTemplate); the edit
                             box shows just the host (ToString/TextSearch) which is what gets connected to. -->
                        <ComboBox x:Uid="cbxHost" x:Name="cbxHost" Style="{StaticResource HostErrorStyle}" IsEditable="True" StaysOpenOnEdit="True"
                                  IsTextSearchEnabled="True" TextSearch.TextPath="Host"
                                  HorizontalAlignment="Left" VerticalAlignment="Center" MinHeight="24" Width="240"
                                  ItemsSource="{Binding DiscoveredHosts}" SelectionChanged="cbxHost_SelectionChanged"
                                  ToolTip="Type an IP address or hostname to connect to, or pick one discovered by Scan network.">
                            <ComboBox.Text>
                                <Binding Path="IpAddress" Mode="TwoWay" ValidatesOnNotifyDataErrors="True" ValidatesOnDataErrors="True" NotifyOnValidationError="True" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <local:HostnameOrIPValueRule ValidatesOnTargetUpdated="True" />
                                    </Binding.ValidationRules>
                                </Binding>
                            </ComboBox.Text>
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Display}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Top">
                        <Button x:Uid="btn_scanNetwork" x:Name="btnScan" Content="Scan network" HorizontalAlignment="Left" Margin="80,0,0,0" MinWidth="120" MinHeight="23" Padding="8,2" Click="btnScan_Click"
                                ToolTip="Scan the local network for grblHAL controllers and list them above."/>
                        <TextBlock x:Name="scanStatus" VerticalAlignment="Center" Margin="10,0,0,0" Opacity="0.7"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>
            <TabItem x:Uid="tab_simulator" x:Name="tabSimulator" Header="Simulator">
                <!-- Enabled only once a simulator has been built to %AppData%\Simulator\grblHAL_sim.exe (see
                     PortDialog.xaml.cs UpdateSimulatorAvailability, and Settings > Simulator / SimulatorConfigView
                     which builds it). When present, Ok launches it (if not already running) and connects to
                     127.0.0.1 on the port below. -->
                <Grid Margin="5,8,5,8" Grid.IsSharedSizeScope="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="simlbl"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label x:Uid="lbl_simPort" Grid.Row="0" Grid.Column="0" Content="Port:" HorizontalContentAlignment="Right" VerticalAlignment="Center" Margin="0,4,8,0"/>
                    <local:NumericTextBox Grid.Row="0" Grid.Column="1" Width="90" HorizontalAlignment="Left" Margin="0,4,0,0" Format="####0">
                        <local:NumericTextBox.Value>
                            <Binding Path="NetPort" Mode="TwoWay" ValidatesOnNotifyDataErrors="True" ValidatesOnDataErrors="True" NotifyOnValidationError="True" UpdateSourceTrigger="PropertyChanged">
                                <Binding.ValidationRules>
                                    <local:NumericRangeRule Min="0" Max="65535" ValidatesOnTargetUpdated="True" />
                                </Binding.ValidationRules>
                            </Binding>
                        </local:NumericTextBox.Value>
                    </local:NumericTextBox>

                    <TextBlock x:Uid="txt_simHint" x:Name="txtSimHint" Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" TextWrapping="Wrap" MaxWidth="340" Opacity="0.75"/>
                </Grid>
            </TabItem>
        </TabControl>
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,10">
            <Button x:Uid="btn_ok" x:Name="btnOk" Content="Ok" MinHeight="23" MinWidth="70" Padding="8,2" Click="btnOk_Click"/>
            <Button x:Uid="btn_cancel" x:Name="btnCancel" Content="Cancel" Margin="5,0,0,0" MinHeight="23" MinWidth="70" Padding="8,2" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
