<UserControl x:Class="CNC.Controls.JobControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:CNC.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="36" d:DesignWidth="400">
    <UserControl.Resources>
        <system:String x:Uid="str_toolchangeTLO" x:Key="JobToolReference">Job has {0} tool change(s), tool length reference should be established before start.</system:String>
        <system:String x:Uid="str_g28g30" x:Key="JobG28G30">Job has G28/G30 moves and machine is not homed.</system:String>
        <system:String x:Uid="str_stop" x:Key="JobStop">Stop</system:String>
        <system:String x:Uid="str_pause" x:Key="JobPause">Pause</system:String>
        <system:String x:Uid="str_checking" x:Key="Checking">Checking...</system:String>
        <system:String x:Uid="str_dryrun" x:Key="DryRun">Dry run - spindle/coolant forced off...</system:String>
        <system:String x:Uid="str_transferComplete" x:Key="TransferComplete">Transfer complete</system:String>
        <!-- Buttons hug their label (one space of padding each side) so the run button row stays compact and
             leaves room for the jog pad to its right. No MinWidth/MaxWidth - each button is content-sized. -->
        <Style x:Key="JobButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <!-- Cycle Start glows green when a wizard program is the active source and ready to run ("press me"). -->
        <Style x:Key="CycleStartButtonStyle" TargetType="Button" BasedOn="{StaticResource JobButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding Path=IsActiveProgramReady, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                    <Setter Property="Background" Value="#FF4CAF50"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <StackPanel Orientation="Horizontal">
        <Button x:Uid="btn_cycleStart" x:Name="btnStart" Content="Cycle Start" ToolTip="Alt+R" Style="{StaticResource CycleStartButtonStyle}" IsEnabled="{Binding Path=IsCycleStartEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}" Click="btnStart_Click">
            <Button.ContextMenu>
                <!-- Grbl check mode ($C): the controller parses g-code without moving, to dry-run/validate a
                     program. Moved here off the status bar; IsChecked mirrors the live GrblViewModel.IsCheckMode. -->
                <ContextMenu Opened="cycleStartMenu_Opened">
                    <MenuItem x:Uid="mnu_checkMode" x:Name="miCheckMode" Header="Check mode ($C)" IsCheckable="True"
                              IsChecked="{Binding Path=IsCheckMode, Mode=OneWay}" Click="miCheckMode_Click"
                              ToolTip="Toggle grbl check mode - the controller parses the program without moving, to validate it before a real run."/>
                    <!-- Sender-side toggle (not a grbl state): the next run offsets Z up by 10mm + stock thickness
                         (G92) AND forces the spindle/coolant off for the whole run, REGARDLESS of what the loaded
                         program contains - M3/M4/M7/M8 lines are neutralised as they're sent, and M5/M9 are sent
                         as a preamble in case the spindle/coolant were already on. Lets the toolpath be watched
                         move without cutting or spinning. See GrblViewModel.IsDryRunMode / JobControl.CycleStart. -->
                    <MenuItem x:Uid="mnu_dryRun" x:Name="miDryRun" Header="Dry run (spindle/coolant forced off)" IsCheckable="True"
                              IsChecked="{Binding Path=IsDryRunMode, Mode=OneWay}" Click="miDryRun_Click"
                              ToolTip="Next run: offset Z clear of stock AND force the spindle/coolant off for the whole run, regardless of what the program contains - watch the toolpath without cutting or spinning anything."/>
                </ContextMenu>
            </Button.ContextMenu>
        </Button>
        <Button x:Uid="btn_feedHold" x:Name="btnHold" Content="Feed Hold" ToolTip="Space" Style="{StaticResource JobButtonStyle}" IsEnabled="{Binding Path=IsFeedHoldEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}" Margin="5,0,0,0" Click="btnHold_Click"/>
        <Button x:Uid="btn_stop" x:Name="btnStop" Content="Stop" ToolTip="Alt+S" Style="{StaticResource JobButtonStyle}" IsEnabled="{Binding Path=IsStopEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}" Margin="5,0,0,0" Click="btnStop_Click"/>
        <Button x:Uid="btn_rewind" x:Name="btnRewind" Content="Rewind" Style="{StaticResource JobButtonStyle}" IsEnabled="{Binding Path=IsRewindEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}" Margin="5,0,0,0" Click="btnRewind_Click"/>
    </StackPanel>
</UserControl>
