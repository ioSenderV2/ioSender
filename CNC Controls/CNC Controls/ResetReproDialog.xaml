<Window x:Class="CNC.Controls.ResetReproDialog"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CNC.Controls"
             mc:Ignorable="d"
             d:DesignHeight="220" d:DesignWidth="260"
             SizeToContent="WidthAndHeight" ResizeMode="NoResize" MinWidth="260"
             Title="Generate reset test case" Loaded="Window_Loaded" Icon="App.ico">
    <Grid Background="#FFE5E5E5">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Height="Auto" Margin="5,5">
            <TextBlock x:Uid="txt_reset_repro_info" Text="Writes a .nc file with an O-word subroutine, called several times, that dwells then moves. grblHAL only allows O-word flow control when running from a file-backed stream, so UPLOAD this file to SD Card / the on-board filesystem and RUN it from the SD Card tab - loading it as a normal job will fail with error:80. Press Reset mid-call to test the controller-wedge repro; try the same file over both Serial and Telnet." TextWrapping="Wrap" MaxWidth="240" Margin="0,0,0,10"/>
            <local:NumericField x:Uid="fld_reset_repro_dwell" x:Name="Dwell" Label="Dwell:" ColonAt="90" Unit="s" Format="##0.#" Value="{Binding Path=Dwell, Mode=TwoWay}"/>
            <local:NumericField x:Uid="fld_reset_repro_travel" x:Name="Travel" Label="Travel distance:" ColonAt="90" Unit="mm" Format="##0.#" Value="{Binding Path=Travel, Mode=TwoWay}"/>
            <local:NumericField x:Uid="fld_reset_repro_feed" x:Name="Feed" Label="Feed rate:" ColonAt="90" Unit="mm/min" Format="##0" Value="{Binding Path=Feed, Mode=TwoWay}"/>
            <local:NumericField x:Uid="fld_reset_repro_calls" x:Name="Calls" Label="Number of calls:" ColonAt="90" Format="##0" Value="{Binding Path=Calls, Mode=TwoWay}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Width="Auto" Margin="0,10,0,0">
                <Button x:Uid="btn_reset_repro_generate" x:Name="btnGenerate" Content="Generate..." HorizontalAlignment="Left" VerticalAlignment="Top" MinWidth="75" Click="btnGenerate_Click"/>
                <Button x:Uid="btn_close" x:Name="btnClose" Content="Close" HorizontalAlignment="Left" Margin="5,0,0,0" VerticalAlignment="Top" MinWidth="75" Click="btnClose_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
