<Window x:Class="CNC.Controls.AppMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        d:DesignHeight="140" d:DesignWidth="380"
        SizeToContent="WidthAndHeight" ResizeMode="NoResize" MinWidth="260"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" Title="ioSender" Icon="App.ico">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="btnYes" Content="Yes" Click="Button_Click" MinWidth="75" MinHeight="24"/>
            <Button x:Name="btnNo" Content="No" Click="Button_Click" MinWidth="75" MinHeight="24" Margin="6,0,0,0"/>
            <Button x:Name="btnOk" Content="OK" Click="Button_Click" MinWidth="75" MinHeight="24"/>
            <Button x:Name="btnCancel" Content="Cancel" Click="Button_Click" MinWidth="75" MinHeight="24" Margin="6,0,0,0"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Image x:Name="imgIcon" Width="32" Height="32" VerticalAlignment="Top" Margin="0,0,14,0" Stretch="None"/>
            <TextBlock x:Name="txtMessage" TextWrapping="Wrap" MaxWidth="440" VerticalAlignment="Center" FontSize="13"/>
        </StackPanel>
    </DockPanel>
</Window>
