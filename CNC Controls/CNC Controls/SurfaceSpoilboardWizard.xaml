<UserControl x:Class="CNC.Controls.SurfaceSpoilboardWizard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CNC.Controls"
             mc:Ignorable="d"
             d:DesignHeight="480" d:DesignWidth="980"
             Loaded="UserControl_Loaded">
    <Grid VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="380" MaxWidth="440"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- Left: inputs -->
        <StackPanel Grid.Column="0" Orientation="Vertical" Margin="5,5,0,0" HorizontalAlignment="Left" MinWidth="370">
            <local:NumericField x:Uid="fld_sbdiameter" Label="Bit diameter:" ColonAt="140" Format="###0.0##"
                Value="{Binding BitDiameter, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}" Unit="mm"/>
            <local:NumericField x:Uid="fld_sbmaxrpm" Label="Bit max RPM:" ColonAt="140" Format="######0"
                Value="{Binding BitMaxRPM, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}" Unit=""/>
            <local:NumericField x:Uid="fld_sbrpm" Label="Spindle RPM:" ColonAt="140" Format="######0"
                Value="{Binding SpindleRPM, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}" Unit=""/>
            <local:NumericField x:Uid="fld_sboverlap" Label="Overlap:" ColonAt="140" Format="##0"
                Value="{Binding Overlap, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}" Unit="%"/>
            <local:NumericField x:Uid="fld_sbstepover" Label="Stepover:" ColonAt="140" IsReadOnly="True" Format="###0.0##"
                Value="{Binding Stepover, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=OneWay}" Unit="mm"/>
            <local:NumericField x:Uid="fld_sbfeed" Label="Feed rate:" ColonAt="140" Format="######0"
                Value="{Binding Feed, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}" Unit="mm/min"/>
            <local:NumericField x:Uid="fld_sbplunge" Label="Plunge feed:" ColonAt="140" Format="######0"
                Value="{Binding PlungeFeed, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}" Unit="mm/min"/>
            <local:NumericField x:Uid="fld_sbdoc" Label="Depth of cut:" ColonAt="140" Format="###0.0##"
                Value="{Binding DepthOfCut, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}" Unit="mm"/>
            <local:NumericField x:Uid="fld_sbtotal" Label="Total depth:" ColonAt="140" Format="###0.0##"
                Value="{Binding TotalDepth, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}" Unit="mm"/>
            <local:NumericField x:Uid="fld_sbsafez" Label="Safe Z:" ColonAt="140" Format="###0.0##"
                Value="{Binding SafeZ, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}" Unit="mm"/>
            <local:NumericField x:Uid="fld_sbwidth" Label="Area width:" ColonAt="140" Format="#####0.0"
                Value="{Binding WidthMM, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}" Unit="mm"/>
            <local:NumericField x:Uid="fld_sbheight" Label="Area height:" ColonAt="140" Format="#####0.0"
                Value="{Binding HeightMM, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}, Mode=TwoWay}" Unit="mm"/>
            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                <Label x:Uid="lbl_sbtool" Content="Tool:" Width="140" Padding="0,0,4,0" HorizontalContentAlignment="Right" VerticalAlignment="Center"/>
                <ComboBox x:Name="cbxTool" Width="90" MinHeight="22" VerticalAlignment="Center" SelectionChanged="cbxTool_SelectionChanged"
                          ToolTip="Loaded: the surfacing bit is already in the spindle (no tool change). Prompt: the program issues a tool change (M6) so it is loaded before surfacing.">
                    <ComboBoxItem x:Uid="cbi_sbtoolLoaded" Content="Loaded"/>
                    <ComboBoxItem x:Uid="cbi_sbtoolPrompt" Content="Prompt"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Right">
                <Button x:Uid="btn_sbgen" Content="Generate" Tag="generate" Focusable="False" MinWidth="80" MinHeight="24" Margin="3,0" Click="Button_Click"/>
            </StackPanel>
            <TextBlock x:Name="txtWarnings" Foreground="#C62828" Margin="5,8" HorizontalAlignment="Left" MinWidth="350" MaxWidth="430" TextWrapping="Wrap"/>
        </StackPanel>
        <!-- Right: summary + instructions -->
        <Grid Grid.Column="1" Margin="8,5,5,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="txtSummary" Grid.Row="0" FontWeight="SemiBold" Margin="0,0,0,6" TextWrapping="Wrap"/>
            <TextBox x:Name="txtInstructions" Grid.Row="1" Background="#FFF8F8F8" IsReadOnly="True" Margin="0,0,0,0" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
        </Grid>
    </Grid>
</UserControl>
