<UserControl x:Class="CNC.Controls.GrblConfigControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:CNC.Controls"
             xmlns:cnccore="clr-namespace:CNC.Core;assembly=CNC.Core"
             mc:Ignorable="d" 
             d:DesignHeight="480" d:DesignWidth="980"
             Loaded="ConfigView_Loaded"
             SizeChanged="ConfigView_SizeChanged"
             KeyDown="ConfigView_KeyDown">
    <UserControl.Resources>
        <system:String x:Uid="str_saveSettings" x:Key="SaveSettings">Settings changed, save now?</system:String>
        <system:String x:Uid="str_resetGrblDefaults" x:Key="ResetGrblDefaults">Restore ALL controller settings to firmware defaults ($RST=$)? This overwrites the current $ settings on the machine.</system:String>
        <system:String x:Uid="str_settingsWritten" x:Key="SettingsWritten">All settings written to {0} in the sender folder.</system:String>
        <system:String x:Uid="str_settingsError" x:Key="SettingsError">Setting {0} returned {1}, continue?</system:String>
        <system:String x:Uid="str_settingsTimeout" x:Key="SettingsTimeout">Timed out while setting {0}, continue?</system:String>
        <system:String x:Uid="str_settingsFail" x:Key="SettingsFail">Bummer...\nContinue loading?</system:String>
        <system:String x:Uid="str_settingsInvalid" x:Key="SettingsInvalid">The file does not contain any settings.</system:String>
        <system:String x:Uid="str_settingsRestore" x:Key="SettingsRestore">Restore settings from file</system:String>
        <system:String x:Uid="str_settingsReloadMismatch" x:Key="SettingsReloadMismatch">{0} settings were ignored, not supported by the controller.</system:String>
        <local:LogicalNotConverter x:Key="IsNotConverter" />
        <local:GrblStateToBooleanConverter x:Key="StateToBooleanConverter" />
        <Style x:Key="NumericErrorStyle" TargetType="local:NumericTextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="true">
                    <Setter Property="local:NumericTextBox.ToolTip">
                        <Setter.Value>
                            <Binding RelativeSource="{RelativeSource Self}" Path="(Validation.Errors)[0].ErrorContent" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StringErrorStyle" TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="true">
                    <Setter Property="TextBox.ToolTip">
                        <Setter.Value>
                            <Binding RelativeSource="{RelativeSource Self}" Path="(Validation.Errors)[0].ErrorContent" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="Ip4ErrorStyle" TargetType="TextBox">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="true">
                    <Setter Property="TextBox.ToolTip">
                        <Setter.Value>
                            <Binding RelativeSource="{RelativeSource Self}" Path="(Validation.Errors)[0].ErrorContent" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ConfigButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="90" />
            <Setter Property="MaxWidth" Value="120" />
            <Setter Property="Padding" Value="5,0" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <!-- Highlight for settings/groups. Blue = value saved to the controller this session but still
             different from the value at startup. Orange/bold = unsaved edit (takes precedence). -->
        <Style x:Key="ModifiedTextStyle" TargetType="TextBlock">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSavedModified}" Value="True">
                    <Setter Property="Foreground" Value="#1565C0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsEdited}" Value="True">
                    <Setter Property="FontWeight" Value="Bold" />
                    <Setter Property="Foreground" Value="#E07B00" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!-- Search highlight: matching settings in the tree get a soft background. Bound to GrblSettingDetails.IsMatch;
             on a GrblSettingGroup (no such property) the trigger simply never fires. -->
        <Style x:Key="MatchRowStyle" TargetType="StackPanel">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMatch}" Value="True">
                    <Setter Property="Background" Value="#FFFFE08A" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!-- Row context menu for the classic-grbl DataGrid (kept out of the row Style, which
             cannot host event handlers). DataContext resolves to the row's GrblSettingDetails. -->
        <ContextMenu x:Key="SettingRowMenu">
            <MenuItem x:Uid="mnu_revertStartup" Header="Revert to value at startup" IsEnabled="{Binding IsModified}" Click="settingRevertStartup_Click" />
        </ContextMenu>
    </UserControl.Resources>
    <DockPanel>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="6*"/>
                <RowDefinition Height="96*"/>
            </Grid.RowDefinitions>
            <StackPanel x:Name="searchPanel" Orientation="Horizontal" Margin="10,5,0,0" VerticalAlignment="Bottom">
                <TextBlock x:Uid="lbl_searchSetting" Text="Search:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <!-- Search text and the "n of m" readout share one border/background: the TextBox is borderless
                     inside a Border that also holds the count, so they read as a single field. -->
                <Border BorderBrush="#FFABADB3" BorderThickness="1" Background="White" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Uid="fld_searchSetting" x:Name="searchBox" Width="300" BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"
                                 TextChanged="searchBox_TextChanged" KeyDown="searchBox_KeyDown"
                                 ToolTip="Search settings: $53 jumps to a setting; $5? expands all of $50-$59; text like Jog (or a bare number like 10) highlights every setting whose name or value contains it. Enter / F3 = next match, F4 = previous."/>
                        <TextBlock x:Name="txtMatchCount" VerticalAlignment="Center" Margin="6,0,8,0" Foreground="#FF606060" MinWidth="56"/>
                    </StackPanel>
                </Border>
                <Button x:Uid="btn_matchPrev" x:Name="btnMatchPrev" Content="▲" MinWidth="26" Padding="4,1" Margin="4,0,0,0" VerticalAlignment="Center" VerticalContentAlignment="Center" Click="btnMatchPrev_Click" IsEnabled="False" ToolTip="Previous match (F4)"/>
                <Button x:Uid="btn_matchNext" x:Name="btnMatchNext" Content="▼" MinWidth="26" Padding="4,1" Margin="2,0,0,0" VerticalAlignment="Center" VerticalContentAlignment="Center" Click="btnMatchNext_Click" IsEnabled="False" ToolTip="Next match (F3)"/>
            </StackPanel>
            <TreeView x:Name="treeView" Grid.Row="1" HorizontalAlignment="Left" Margin="10,5,0,10" VerticalAlignment="Stretch"
                      Width="{Binding ActualWidth, ElementName=searchPanel}" MinWidth="390" SelectedItemChanged="treeView_SelectedItemChanged" Grid.RowSpan="2">
                <TreeView.Resources>
                    <HierarchicalDataTemplate DataType="{x:Type cnccore:GrblSettingGroup}" ItemsSource="{Binding Settings}" >
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.ContextMenu>
                                <ContextMenu>
                                    <MenuItem x:Uid="mnu_revertGroup" Header="Revert all in group to value at startup" IsEnabled="{Binding IsModified}" Click="groupRevertStartup_Click" />
                                </ContextMenu>
                            </StackPanel.ContextMenu>
                            <TextBlock Text="{Binding Name}" Style="{StaticResource ModifiedTextStyle}" />
                        </StackPanel>
                    </HierarchicalDataTemplate>
                    <DataTemplate DataType="{x:Type cnccore:GrblSettingDetails}" >
                        <StackPanel Orientation="Horizontal" Style="{StaticResource MatchRowStyle}">
                            <StackPanel.ContextMenu>
                                <ContextMenu>
                                    <MenuItem x:Uid="mnu_revertStartup2" Header="Revert to value at startup" IsEnabled="{Binding IsModified}" Click="settingRevertStartup_Click" />
                                </ContextMenu>
                            </StackPanel.ContextMenu>
                            <TextBlock Text="{Binding Id}" Margin="0,0,5,0" Style="{StaticResource ModifiedTextStyle}" />
                            <TextBlock Text="{Binding Name, StringFormat=\{0\}:}" Style="{StaticResource ModifiedTextStyle}" />
                            <TextBlock Text="{Binding FormattedValue}" Margin="5,0" Style="{StaticResource ModifiedTextStyle}"
                                       ToolTip="{Binding BitfieldLabels}" ToolTipService.ShowOnDisabled="True" />
                            <TextBlock Text="{Binding Unit}" Style="{StaticResource ModifiedTextStyle}" />
                        </StackPanel>
                    </DataTemplate>
                </TreeView.Resources>
            </TreeView>
        </Grid>
        <DataGrid x:Name="dgrSettings" DockPanel.Dock="Left" ItemsSource="{Binding}" IsReadOnly="True" HorizontalAlignment="Left" Margin="10,10" VerticalAlignment="Stretch" Width="390"
                  SelectionMode="Single" SelectionUnit="FullRow" AutoGenerateColumns="False" Visibility="Collapsed"
                  CanUserReorderColumns="False" CanUserResizeColumns="False" CanUserResizeRows="False" CanUserSortColumns="False" CanUserAddRows="False" SelectionChanged="dgrSettings_SelectionChanged">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="ContextMenu" Value="{StaticResource SettingRowMenu}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSavedModified}" Value="True">
                            <Setter Property="Foreground" Value="#1565C0" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsEdited}" Value="True">
                            <Setter Property="FontWeight" Value="Bold" />
                            <Setter Property="Foreground" Value="#E07B00" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn x:Uid="hdr_settingId" Header="Id" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn x:Uid="hdr_settingValue" Header="Value" Binding="{Binding EditValue}" Width="70"/>
                <DataGridTextColumn x:Uid="hdr_settingUnit" Header="Unit" Binding="{Binding Unit}" Width="80"/>
                <DataGridTextColumn x:Uid="hdr_settingName" Header="Name" Binding="{Binding Name}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <DockPanel x:Name="dpan" DockPanel.Dock="Left">
            <!-- Reload / Save / Backup / Restore / Copy-to-sim live in the shared Settings footer's Grbl sub-footer
                 (GrblConfigView), so the whole Settings area has one consistent footer. -->
            <!-- Auto row: the selected setting's edit field(s); * row: the description box fills the rest.
                 This lets the field always take its full height (it is no longer clipped by the box below)
                 and the box fill the remaining area via layout - no code-computed height needed. -->
            <Grid x:Name="details" DockPanel.Dock="Top" HorizontalAlignment="Left" VerticalAlignment="Stretch" Margin="5,16,0,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel x:Name="canvas" Grid.Row="0" HorizontalAlignment="Left" MinHeight="30" Width="455" VerticalAlignment="Top"/>
                <TextBox x:Name="txtDescription" Grid.Row="1" Background="#FFF8F8F8" IsReadOnly="True" Margin="5,10,0,0" HorizontalAlignment="Left" MinHeight="120" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Width="550"/>
                <!-- Live config check: step pulse ($0) vs worst-case step rate (steps/mm x max feed rate). -->
                <TextBlock x:Name="txtValidation" Grid.Row="2" Foreground="#C62828" TextWrapping="Wrap" Margin="5,6,0,0" MaxWidth="550" HorizontalAlignment="Left" Visibility="Collapsed"/>
            </Grid>
        </DockPanel>
    </DockPanel>
</UserControl>
