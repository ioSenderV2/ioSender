<UserControl x:Class="CNC.Controls.TrinamicView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CNC.Controls"
             xmlns:gcode="clr-namespace:CNC.GCode;assembly=CNC.Core"
             mc:Ignorable="d" 
             d:DesignHeight="480" d:DesignWidth="875"
             Loaded="TrinamicView_Loaded">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="SharedStyles.xaml"/>
                <ResourceDictionary>
                    <local:LogicalNotConverter x:Key="BooleanConverter" />
                    <local:BoolToVisibleConverter x:Key="IsVisibleConverter" />
                    <local:PositionToStringConverter x:Key="PositionConverter" />
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <DockPanel Background="Transparent" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
        <DockPanel x:Name="dp" DockPanel.Dock="Left" Margin="5,5,5,0" MinWidth="520" HorizontalAlignment="Left" VerticalAlignment="Stretch">
            <StackPanel DockPanel.Dock="Top" MinWidth="520" VerticalAlignment="Stretch">
                <Border BorderThickness="1" BorderBrush="DarkGray" Height="242" Width="514" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Canvas x:Name="SGPlot" Background="WhiteSmoke" HorizontalAlignment="Left" Height="240" VerticalAlignment="Top" Width="512"/>
                </Border>
                <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Uid="tmc_axisX" Content="X" IsChecked="{Binding Path=AxisEnabled[(gcode:AxisFlags)X], RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="5,0" ToolTip="Show and tune the X axis stepper driver."/>
                        <RadioButton x:Uid="tmc_axisY" Content="Y" IsChecked="{Binding Path=AxisEnabled[(gcode:AxisFlags)Y], RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" Style="{StaticResource YAxisVisibleStyle}" Margin="5,0" HorizontalAlignment="Left" VerticalAlignment="Center" ToolTip="Show and tune the Y axis stepper driver."/>
                        <RadioButton x:Uid="tmc_axisZ" Content="Z" IsChecked="{Binding Path=AxisEnabled[(gcode:AxisFlags)Z], RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" Style="{StaticResource ZAxisVisibleStyle}" Margin="5,0" HorizontalAlignment="Left" VerticalAlignment="Center" ToolTip="Show and tune the Z axis stepper driver."/>
                        <RadioButton x:Uid="tmc_axisA" Content="A" IsChecked="{Binding Path=AxisEnabled[(gcode:AxisFlags)A], RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" Style="{StaticResource AAxisVisibleStyle}" Margin="5,0" HorizontalAlignment="Left" VerticalAlignment="Center" ToolTip="Show and tune the A axis stepper driver."/>
                        <RadioButton x:Uid="tmc_axisB" Content="B" IsChecked="{Binding Path=AxisEnabled[(gcode:AxisFlags)B], RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" Style="{StaticResource BAxisVisibleStyle}" Margin="5,0" HorizontalAlignment="Left" VerticalAlignment="Center" ToolTip="Show and tune the B axis stepper driver."/>
                        <RadioButton x:Uid="tmc_axisC" Content="C" IsChecked="{Binding Path=AxisEnabled[(gcode:AxisFlags)C], RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" Style="{StaticResource CAxisVisibleStyle}" Margin="5,0" HorizontalAlignment="Left" VerticalAlignment="Center" ToolTip="Show and tune the C axis stepper driver."/>
                    </StackPanel>
                    <Label x:Uid="lbl_sgLoad" x:Name="lblLoad" Content="Load (SG_RESULT)" Foreground="Blue" Margin="0,0,5,0" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
                <GroupBox x:Uid="grp_stallGuard" Header="stallGuard">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <Slider Value="{Binding SGValue, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" MinWidth="169" Minimum="{Binding Path=SGValueMin, RelativeSource={RelativeSource AncestorType=UserControl}}" Maximum="{Binding Path=SGValueMax, RelativeSource={RelativeSource AncestorType=UserControl}}" TickPlacement="BottomRight" IsSnapToTickEnabled="False" LostMouseCapture="Slider_LostMouseCapture"/>
                            <TextBox Text="{Binding Path=SGValue, RelativeSource={RelativeSource AncestorType=UserControl}, StringFormat='##0'}" HorizontalContentAlignment="Right" IsReadOnly="True" MinWidth="30" Margin="5,0,0,0" />
                            <Button x:Uid="lbl_configure" Content="Configure" MinWidth="60" VerticalAlignment="Center" Margin="5,0" Padding="6,0" Click="btnConfigureSGVal_Click" ToolTip="Store the slider's stallGuard threshold to the selected axis' driver."/>
                            <CheckBox x:Uid="lbl_stallGuardEnable" IsChecked="{Binding Path=SFiltEnabled, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" Content="Enable filter (SFILT)" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center" ToolTip="Filter the SG_RESULT reading for a steadier load signal at the cost of slower response."/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
                <DockPanel>
                    <local:StatusControl DockPanel.Dock="Left" Margin="0,5,0,0" VerticalAlignment="Bottom"/>
                    <local:SignalsControl DockPanel.Dock="Right" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
                </DockPanel>
            </StackPanel>
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,5,0,0">
                <local:MDIControl x:Name="mdiControl"/>
                <TextBlock TextWrapping="NoWrap" MinWidth="235" HorizontalAlignment="Left" Margin="0,5,0,0">
                    <TextBlock.Text>
                        <MultiBinding Converter="{StaticResource PositionConverter}">
                            <Binding Path="Position"/>
                            <Binding Path="Format"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </DockPanel>
        <Grid DockPanel.Dock="Top" Margin="0,5,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" Margin="0,0,0,8">
                <TextBlock x:Uid="hlp_tmcHdr" Text="About the Trinamic tuner" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <TextBlock x:Uid="hlp_tmcBody" TextWrapping="Wrap"
                           Text="For machines fitted with Trinamic stepper drivers: tune StallGuard (used for sensorless homing and load detection) and read live driver diagnostics.&#10;&#10;Pick an axis and jog it, then watch the SG_RESULT load plot on the left. Set the stallGuard threshold with the slider so the trace stays high under normal load and drops toward zero as the axis stalls, then Configure to store it. Get status prints the selected driver's registers (temperature, current, fault flags); Get status, all drivers prints every axis."/>
            </StackPanel>
            <TextBox Grid.Row="1" Text="{Binding Path=DriverStatus, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=OneWay}" IsReadOnly="True" HorizontalAlignment="Stretch" TextWrapping="Wrap" VerticalAlignment="Stretch" FontSize="12" FontFamily="Global Monospace"/>
            <StackPanel Grid.Row="2" Orientation="Horizontal">
                <Button x:Uid="btn_getStatus" Content="Get status" MinWidth="130" HorizontalAlignment="Left" VerticalAlignment="Center" Click="btnGetState_Click" ToolTip="Print the selected axis driver's registers (temperature, current, fault flags) above."/>
                <Button x:Uid="btn_getStatusAll" Content="Get status, all drivers" MinWidth="130" Margin="5,0" HorizontalAlignment="Left" VerticalAlignment="Center" Click="btnGetStateAll_Click" ToolTip="Print status registers for every enabled axis' driver above."/>
            </StackPanel>
        </Grid>
    </DockPanel>
</UserControl>
