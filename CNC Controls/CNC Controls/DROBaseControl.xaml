<UserControl x:Class="CNC.Controls.DROBaseControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CNC.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="33" d:DesignWidth="193">
    <UserControl.Resources>
        <local:LogicalNotConverter x:Key="BooleanConverter" />
    </UserControl.Resources>
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" MinWidth="193" RenderTransformOrigin="0.425,0">
        <!-- NOT a NumericField candidate despite IsReadOnly="True" here: DROControl.xaml.cs wires GotFocus/
             LostFocus/PreviewKeyDown/PreviewKeyUp directly onto this control to implement click-to-type-a-
             coordinate (temporarily flips IsReadOnly off + swaps Background on focus, casts sender straight
             to NumericTextBox) - it's a real editable field wearing a read-only default, not a static
             readout. Converting it broke that focus choreography (InvalidCastException on any focus event,
             first surfaced via a right-click). Left as bare NumericTextBox on purpose. -->
        <Label x:Name="lblAxis" Content="{Binding Label, RelativeSource={RelativeSource AncestorType=UserControl}}" HorizontalContentAlignment="Right" VerticalContentAlignment="Center" Margin="3,0,3,0" MinWidth="30" FontSize="20"/>
        <local:NumericTextBox x:Name="txtReadout" Format="{Binding Path=FormatSigned}" Value="{Binding Path=Value, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" IsReadOnly="True" Background="#FFF8F8F8" MinWidth="103" TextWrapping="NoWrap" TextAlignment="Right" FontSize="20"/>
        <Button x:Uid="btnZero" x:Name="btnZero" Content="0" IsEnabled="{Binding Path=IsJobRunning, Converter={StaticResource BooleanConverter}}" Focusable="False" Margin="3,0,3,0" MinWidth="29" Click="btnZero_Click"
                ToolTip="Set the work coordinate to 0 on this axis at the current position."/>
        <Button x:Uid="btnScaled" x:Name="btnScaled" Focusable="False" Width="10" Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
    </StackPanel>
</UserControl>
