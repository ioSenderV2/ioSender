<UserControl x:Class="CNC.Controls.MachineSetupWizard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CNC.Controls"
             mc:Ignorable="d"
             d:DesignHeight="640" d:DesignWidth="980">
    <UserControl.Resources>
        <!-- Live limit-switch indicator: grey when idle, green when the input is asserted. -->
        <Style x:Key="LimitDot" TargetType="Border">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Background" Value="#FFCCCCCC"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding LimitActive}" Value="True">
                    <Setter Property="Background" Value="LimeGreen"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!-- Clickable home-corner marker on the box. -->
        <Style x:Key="CornerDot" TargetType="Ellipse">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Fill" Value="White"/>
            <Setter Property="Stroke" Value="#FF444444"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#FF1F3A5F"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10" d:DataContext="{d:DesignInstance Type=local:MachineSetupWizard}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,8">
            <TextBlock Text="Machine setup" FontSize="18" FontWeight="Bold"/>
            <TextBlock TextWrapping="Wrap" Foreground="Gray"
                       Text="Describe your machine on one page. Nothing is sent to the controller until you press Apply."/>
            <Separator Margin="0,4"/>
        </StackPanel>

        <!-- Scrollable body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Vertical">

                <!-- Top row: Machine (left) | Home position (right) -->
                <Grid>
                    <!-- Machine capped at 3/5 of the row, Home position gets the remaining 2/5. -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 1. Machine -->
                    <GroupBox Grid.Column="0" Header="1 · Machine" Padding="8" Margin="0,0,8,0" VerticalAlignment="Top">
                        <StackPanel Orientation="Vertical">
                            <DockPanel LastChildFill="False">
                                <TextBlock DockPanel.Dock="Left" Text="Start from your machine" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
                                <Button DockPanel.Dock="Right" x:Name="btnFirmwareInfo" Content="Firmware info…" MinWidth="100" Height="22"
                                        VerticalAlignment="Center" Click="FirmwareInfo_Click"
                                        ToolTip="Show the controller's $I build/version information."/>
                            </DockPanel>
                            <WrapPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <ComboBox x:Name="cbxManufacturer" Width="170" Margin="0,0,6,4" MinHeight="22"
                                          ItemsSource="{Binding Manufacturers, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"
                                          SelectionChanged="Manufacturer_Changed"/>
                                <ComboBox x:Name="cbxProduct" Width="180" Margin="0,0,6,4" MinHeight="22" SelectionChanged="Product_Changed"/>
                                <ComboBox x:Name="cbxModel" Width="240" Margin="0,0,0,4" MinHeight="22" SelectionChanged="Model_Changed"/>
                            </WrapPanel>
                            <TextBlock Text="{Binding PresetNote, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"
                                       TextWrapping="Wrap" Foreground="#FFB45309" Margin="0,2,0,0"/>
                            <TextBlock Foreground="Gray" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="Pick your manufacturer, product and model to fill the fields below. Not listed? Choose Custom / not listed and enter the values by hand."/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 2. Home position -->
                    <GroupBox Grid.Column="1" Header="2 · Home position" Padding="8" VerticalAlignment="Top">
                        <StackPanel Orientation="Vertical">
                            <Canvas Width="330" Height="150" HorizontalAlignment="Left" Background="Transparent"
                                    ToolTip="Click the top corner where your machine homes (looking down from above the front; Z homes at the top).">
                                <!-- box: front face -->
                                <Polygon Points="70,70 230,70 230,120 70,120" Stroke="#FF888888" StrokeThickness="1" Fill="#FFF3F3F3"/>
                                <!-- box: right face -->
                                <Polygon Points="230,70 270,20 270,70 230,120" Stroke="#FF888888" StrokeThickness="1" Fill="#FFE8E8E8"/>
                                <!-- box: top face -->
                                <Polygon Points="70,70 230,70 270,20 110,20" Stroke="#FF666666" StrokeThickness="1" Fill="#FFFAFAFA"/>
                                <!-- axis hints -->
                                <Line X1="70" Y1="135" X2="120" Y2="135" Stroke="#FF3060C0" StrokeThickness="2"/>
                                <TextBlock Canvas.Left="124" Canvas.Top="127" Text="+X" Foreground="#FF3060C0" FontWeight="Bold"/>
                                <Line X1="55" Y1="80" X2="80" Y2="45" Stroke="#FF2E8B57" StrokeThickness="2"/>
                                <TextBlock Canvas.Left="40" Canvas.Top="28" Text="+Y" Foreground="#FF2E8B57" FontWeight="Bold"/>
                                <!-- corner markers (top face) -->
                                <Ellipse x:Name="cornerFL" Style="{StaticResource CornerDot}" Canvas.Left="61" Canvas.Top="61" Tag="FL" MouseLeftButtonDown="Corner_Click" ToolTip="Front-left (X min, Y min)"/>
                                <Ellipse x:Name="cornerFR" Style="{StaticResource CornerDot}" Canvas.Left="221" Canvas.Top="61" Tag="FR" MouseLeftButtonDown="Corner_Click" ToolTip="Front-right (X max, Y min)"/>
                                <Ellipse x:Name="cornerBL" Style="{StaticResource CornerDot}" Canvas.Left="101" Canvas.Top="11" Tag="BL" MouseLeftButtonDown="Corner_Click" ToolTip="Back-left (X min, Y max)"/>
                                <Ellipse x:Name="cornerBR" Style="{StaticResource CornerDot}" Canvas.Left="261" Canvas.Top="11" Tag="BR" MouseLeftButtonDown="Corner_Click" ToolTip="Back-right (X max, Y max)"/>
                            </Canvas>
                        </StackPanel>
                    </GroupBox>
                </Grid>

                <!-- 3. Axis information -->
                <GroupBox Header="3 · Axis information" Padding="8" Margin="0,8,0,0">
                    <StackPanel Orientation="Vertical">
                        <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,6"
                                   Text="Travel is the physical reach in mm (the stored soft-limit travel reserves twice the pull-off). Rate is max feed (mm/min, deg/min for rotaries). Steps/mm comes from your drive - 0 leaves it untouched. Tick Invert dir ($3) to flip an axis, NC limit ($5) for normally-closed switches, Home min ($23) to home an axis toward its minimum (negative) end - kept in sync with the home-corner picture above (Z is fixed to the top). The Live dot lights when grbl sees that limit input."/>
                        <!-- Plain row grid (not a DataGrid) so every numeric cell is a live, single-click textbox. -->
                        <StackPanel Orientation="Vertical">
                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="130"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Axis" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Bottom"/>
                                <TextBlock Grid.Column="1" Text="Travel (mm)" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Bottom"/>
                                <TextBlock Grid.Column="2" Text="Rate (mm/min)" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Bottom"/>
                                <TextBlock Grid.Column="3" Text="Steps/mm" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Bottom"/>
                                <TextBlock Grid.Column="4" Text="Invert dir ($3)" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Bottom"/>
                                <TextBlock Grid.Column="5" Text="NC limit ($5)" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Bottom"/>
                                <TextBlock Grid.Column="6" Text="Home min ($23)" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Bottom"/>
                                <TextBlock Grid.Column="7" Text="Live" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Bottom"/>
                            </Grid>
                            <Separator Margin="0,0,0,2"/>
                            <ItemsControl ItemsSource="{Binding Setup.Axes, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="50"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Letter}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" Margin="2,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"
                                                     Text="{Binding MaxTravel, UpdateSourceTrigger=PropertyChanged}"/>
                                            <TextBox Grid.Column="2" Margin="2,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"
                                                     Text="{Binding MaxRate, UpdateSourceTrigger=PropertyChanged}"/>
                                            <TextBox Grid.Column="3" Margin="2,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"
                                                     Text="{Binding StepsPerMm, UpdateSourceTrigger=PropertyChanged}"/>
                                            <CheckBox Grid.Column="4" IsChecked="{Binding InvertDirection}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <CheckBox Grid.Column="5" IsChecked="{Binding LimitNormallyClosed}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <CheckBox Grid.Column="6" IsChecked="{Binding HomeAtMin}" IsEnabled="{Binding HomingDirEditable}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Border Grid.Column="7" Style="{StaticResource LimitDot}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>

                <!-- 4. Homing & limits -->
                <GroupBox Header="4 · Homing &amp; limits" Padding="8" Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto" MinWidth="220"/>
                        </Grid.ColumnDefinitions>

                        <!-- left: enable toggles (each input carries its own explanation as a tooltip) -->
                        <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,16,0">
                            <CheckBox Content="My machine has limit switches"
                                      ToolTipService.ShowDuration="20000"
                                      ToolTip="Tick if your axes have limit/home switches wired. With switches, hard limits ($21) are enabled automatically (change that later in Basic settings) and homing becomes available."
                                      IsChecked="{Binding Setup.HasLimitSwitches, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"/>
                            <CheckBox Content="Enable homing ($22)" Margin="0,6,0,0"
                                      ToolTipService.ShowDuration="20000"
                                      ToolTip="Run a homing cycle on connect to find machine zero using the limit switches. Required for soft limits, force-set-origin and click-to-jog."
                                      IsChecked="{Binding Setup.HomingEnable, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"/>
                            <CheckBox Content="Force set origin at home ($22 bit 3)" Margin="20,2,0,0"
                                      ToolTipService.ShowDuration="20000"
                                      ToolTip="After homing, set machine zero at the home corner so each axis travels positive per its homing direction. Needed for the home-corner choice and the 3D view to match the real machine - reconnect after applying."
                                      IsEnabled="{Binding Setup.HomingEnable, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"
                                      IsChecked="{Binding Setup.ForceSetOrigin, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"/>
                            <CheckBox Content="Enable soft limits ($20)" Margin="0,6,0,0"
                                      ToolTipService.ShowDuration="20000"
                                      ToolTip="Stop any move that would exceed the travel you entered, with a clean controlled stop. Requires homing; also enables click-to-jog in the 3D view."
                                      IsChecked="{Binding Setup.SoftLimitsEnable, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"/>
                        </StackPanel>

                        <!-- right: homing rates -->
                        <Grid Grid.Column="1" IsEnabled="{Binding Setup.HomingEnable, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Pull-off / back-off ($27):" VerticalAlignment="Center" Margin="0,3,10,3"
                                       ToolTipService.ShowDuration="20000"
                                       ToolTip="Distance each axis backs off the switch after it trips, in mm. Also the clearance reserved at both ends of travel."/>
                            <TextBox  Grid.Row="0" Grid.Column="1" Width="80" ToolTipService.ShowDuration="20000"
                                      ToolTip="Distance each axis backs off the switch after it trips, in mm. Also the clearance reserved at both ends of travel."
                                      Text="{Binding Setup.HomingPulloff, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Locate feed rate ($24):" VerticalAlignment="Center" Margin="0,3,10,3"
                                       ToolTipService.ShowDuration="20000"
                                       ToolTip="Slow feed for the second, precise approach to the switch (mm/min). Lower gives more repeatable homing."/>
                            <TextBox  Grid.Row="1" Grid.Column="1" Width="80" ToolTipService.ShowDuration="20000"
                                      ToolTip="Slow feed for the second, precise approach to the switch (mm/min). Lower gives more repeatable homing."
                                      Text="{Binding Setup.HomingFeed, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Seek rate ($25):" VerticalAlignment="Center" Margin="0,3,10,3"
                                       ToolTipService.ShowDuration="20000"
                                       ToolTip="Fast feed for the first approach that finds the switch (mm/min)."/>
                            <TextBox  Grid.Row="2" Grid.Column="1" Width="80" ToolTipService.ShowDuration="20000"
                                      ToolTip="Fast feed for the first approach that finds the switch (mm/min)."
                                      Text="{Binding Setup.HomingSeek, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Debounce ms ($26):" VerticalAlignment="Center" Margin="0,3,10,3"
                                       ToolTipService.ShowDuration="20000"
                                       ToolTip="Time the switch signal must stay steady before it counts, in milliseconds. Filters electrical noise and contact bounce."/>
                            <TextBox  Grid.Row="3" Grid.Column="1" Width="80" ToolTipService.ShowDuration="20000"
                                      ToolTip="Time the switch signal must stay steady before it counts, in milliseconds. Filters electrical noise and contact bounce."
                                      Text="{Binding Setup.HomingDebounce, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"/>
                        </Grid>
                    </Grid>
                </GroupBox>

                <!-- Pending changes (preview) -->
                <Expander x:Name="expReview" Header="Preview pending changes" Margin="0,8,0,0" Expanded="Review_Expanded">
                    <DataGrid AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" MaxHeight="200" Margin="0,4,0,0"
                              ItemsSource="{Binding Changes, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Setting" Binding="{Binding Setting}" Width="80"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Current" Binding="{Binding OldValue}" Width="120"/>
                            <DataGridTextColumn Header="New" Binding="{Binding NewValue}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <DockPanel Grid.Row="2" Margin="0,8,0,0">
            <Button x:Name="btnForget" DockPanel.Dock="Left" Content="Forget machine" Padding="14,0" Click="Forget_Click"
                    ToolTip="Clear the remembered machine. The Machine Setup Wizard will reappear on the next launch (does not change controller settings)."/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="txtStatus" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="Gray"/>
                <Button x:Name="btnReload" Content="Reload" Width="90" Margin="0,0,6,0" Click="Reload_Click"
                        ToolTip="Discard edits and re-read the current settings from the controller."/>
                <Button x:Name="btnApply" Content="Apply" Width="90" Click="Apply_Click" IsEnabled="False"
                        ToolTipService.ShowDuration="60000" ToolTipOpening="btnApply_ToolTipOpening"
                        ToolTip="Write the changed settings to the controller."/>
            </StackPanel>
        </DockPanel>
    </Grid>
</UserControl>
