<UserControl x:Class="CNC.Controls.MachineSetupWizard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CNC.Controls"
             mc:Ignorable="d"
             d:DesignHeight="640" d:DesignWidth="980">
    <UserControl.Resources>
        <!-- Live limit-switch indicator: grey when idle, green when the input is asserted. -->
        <Style x:Key="LimitDot" TargetType="Border">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Background" Value="#FFCCCCCC"/>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding LimitActive}" Value="True">
                    <Setter Property="Background" Value="LimeGreen"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!-- Clickable home-corner marker on the box. -->
        <Style x:Key="CornerDot" TargetType="Ellipse">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Fill" Value="White"/>
            <Setter Property="Stroke" Value="#FF444444"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#FF1F3A5F"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10" d:DataContext="{d:DesignInstance Type=local:MachineSetupWizard}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,8">
            <TextBlock x:Uid="txt_title" Text="Machine setup" FontSize="18" FontWeight="Bold"/>
            <TextBlock x:Uid="txt_intro" TextWrapping="Wrap" Foreground="Gray"
                       Text="Work through the step tabs below. Nothing is sent to the controller until you press Apply."/>
            <Separator Margin="0,4"/>
        </StackPanel>

        <!-- Body: one tab per setup step -->
        <local:StretchTabControl x:Name="tabSteps" Grid.Row="1" Background="Transparent" SelectionChanged="Steps_SelectionChanged">

            <!-- Overview -->
            <TabItem x:Uid="step_overview" x:Name="tabStepOverview" Header="Overview">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Vertical" Margin="10" MaxWidth="780" HorizontalAlignment="Left">
                        <TextBlock x:Uid="ov_head" Text="Setting up your machine" Style="{StaticResource SectionHeader}" FontSize="15"/>
                        <TextBlock x:Uid="ov_body" TextWrapping="Wrap" Margin="0,4,0,0"
                                   Text="This guided setup describes your machine to ioSender. Work through the tabs left to right - each setup step is its own tab:"/>
                        <TextBlock x:Uid="ov_s1" TextWrapping="Wrap" Margin="0,6,0,0" Text="1 · Machine - pick your make / product / model (or Custom) to pre-fill typical values."/>
                        <TextBlock x:Uid="ov_s2" TextWrapping="Wrap" Margin="0,2,0,0" Text="2 · Home position - the corner your machine homes to."/>
                        <TextBlock x:Uid="ov_s3" TextWrapping="Wrap" Margin="0,2,0,0" Text="3 · Axis information - travel, max rate and steps/mm for each axis."/>
                        <TextBlock x:Uid="ov_s4" TextWrapping="Wrap" Margin="0,2,0,0" Text="4 · Homing &amp; limits - limit switches, homing and soft limits."/>
                        <TextBlock x:Uid="ov_s5" TextWrapping="Wrap" Margin="0,2,0,0" Text="5 · Probe definitions - the probes fitted to this machine."/>
                        <TextBlock x:Uid="ov_s6" TextWrapping="Wrap" Margin="0,2,0,0" Text="6 · Controller macros - install the controller-side macro set."/>
                        <TextBlock x:Uid="ov_foot" TextWrapping="Wrap" Margin="0,8,0,0" Foreground="Gray"
                                   Text="Nothing is sent to the controller until you press Apply. On a connected machine ioSender pre-fills what the controller already reports ($$), so often you just confirm each tab and Apply."/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 1. Machine -->
            <TabItem x:Uid="tabstep_machine" x:Name="tabStepMachine">
                <TabItem.Header><TextBlock x:Uid="step_machine" x:Name="hdrMachine" Text="1 · Machine"/></TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Vertical" Margin="10">
                        <DockPanel LastChildFill="False">
                            <TextBlock x:Uid="txt_startFrom" DockPanel.Dock="Left" Text="Start from your machine" Style="{StaticResource SectionHeader}" VerticalAlignment="Center"/>
                            <Button DockPanel.Dock="Right" x:Name="btnFirmwareInfo" x:Uid="btn_firmwareInfo" Content="Firmware info…" MinWidth="100" MinHeight="22"
                                    VerticalAlignment="Center" Click="FirmwareInfo_Click"
                                    ToolTip="Show the controller's $I build/version information."/>
                        </DockPanel>
                        <WrapPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <ComboBox x:Uid="cbxManufacturer" x:Name="cbxManufacturer" MinWidth="170" Margin="0,0,6,4" MinHeight="22"
                                      ItemsSource="{Binding Manufacturers, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"
                                      SelectionChanged="Manufacturer_Changed"/>
                            <ComboBox x:Uid="cbxProduct" x:Name="cbxProduct" MinWidth="180" Margin="0,0,6,4" MinHeight="22" SelectionChanged="Product_Changed"/>
                            <ComboBox x:Uid="cbxModel" x:Name="cbxModel" MinWidth="240" Margin="0,0,0,4" MinHeight="22" SelectionChanged="Model_Changed"/>
                        </WrapPanel>
                        <TextBlock Text="{Binding PresetNote, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"
                                   TextWrapping="Wrap" Foreground="#FFB45309" Margin="0,2,0,0"/>
                        <TextBlock x:Uid="txt_pickHint" Foreground="Gray" TextWrapping="Wrap" Margin="0,4,0,0"
                                   Text="Pick your manufacturer, product and model to fill the fields below. Not listed? Choose Custom / not listed and enter the values by hand."/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 2. Home position -->
            <TabItem x:Uid="tabstep_home" x:Name="tabStepHome">
                <TabItem.Header><TextBlock x:Uid="step_homePos" x:Name="hdrHome" Text="2 · Home position"/></TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Vertical" Margin="10">
                        <Canvas x:Uid="cnv_homeBox" Width="330" Height="150" HorizontalAlignment="Left" Background="Transparent"
                                ToolTip="Click the top corner where your machine homes (looking down from above the front; Z homes at the top).">
                            <!-- box: front face -->
                            <Polygon Points="70,70 230,70 230,120 70,120" Stroke="#FF888888" StrokeThickness="1" Fill="#FFF3F3F3"/>
                            <!-- box: right face -->
                            <Polygon Points="230,70 270,20 270,70 230,120" Stroke="#FF888888" StrokeThickness="1" Fill="#FFE8E8E8"/>
                            <!-- box: top face -->
                            <Polygon Points="70,70 230,70 270,20 110,20" Stroke="#FF666666" StrokeThickness="1" Fill="#FFFAFAFA"/>
                            <!-- axis hints -->
                            <Line X1="70" Y1="135" X2="120" Y2="135" Stroke="#FF3060C0" StrokeThickness="2"/>
                            <TextBlock Canvas.Left="124" Canvas.Top="127" Text="+X" Foreground="#FF3060C0" FontWeight="Bold"/>
                            <Line X1="55" Y1="80" X2="80" Y2="45" Stroke="#FF2E8B57" StrokeThickness="2"/>
                            <TextBlock Canvas.Left="40" Canvas.Top="28" Text="+Y" Foreground="#FF2E8B57" FontWeight="Bold"/>
                            <!-- corner markers (top face) -->
                            <Ellipse x:Name="cornerFL" x:Uid="cornerFL" Style="{StaticResource CornerDot}" Canvas.Left="61" Canvas.Top="61" Tag="FL" MouseLeftButtonDown="Corner_Click" ToolTip="Front-left (X min, Y min)"/>
                            <Ellipse x:Name="cornerFR" x:Uid="cornerFR" Style="{StaticResource CornerDot}" Canvas.Left="221" Canvas.Top="61" Tag="FR" MouseLeftButtonDown="Corner_Click" ToolTip="Front-right (X max, Y min)"/>
                            <Ellipse x:Name="cornerBL" x:Uid="cornerBL" Style="{StaticResource CornerDot}" Canvas.Left="101" Canvas.Top="11" Tag="BL" MouseLeftButtonDown="Corner_Click" ToolTip="Back-left (X min, Y max)"/>
                            <Ellipse x:Name="cornerBR" x:Uid="cornerBR" Style="{StaticResource CornerDot}" Canvas.Left="261" Canvas.Top="11" Tag="BR" MouseLeftButtonDown="Corner_Click" ToolTip="Back-right (X max, Y max)"/>
                        </Canvas>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 3. Axis information -->
            <TabItem x:Uid="tabstep_axis" x:Name="tabStepAxis">
                <TabItem.Header><TextBlock x:Uid="step_axis" x:Name="hdrAxis" Text="3 · Axis information"/></TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Vertical" Margin="10">
                        <TextBlock x:Uid="txt_axisHelp" TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,6"
                                   Text="Travel is the physical reach in mm (the stored soft-limit travel reserves twice the pull-off). Rate is max feed (mm/min, deg/min for rotaries). Steps/mm comes from your drive - 0 leaves it untouched. Tick Invert dir ($3) to flip an axis, NC limit ($5) for normally-closed switches, Home min ($23) to home an axis toward its minimum (negative) end - kept in sync with the home-corner picture above (Z is fixed to the top). The Live dot lights when grbl sees that limit input."/>
                        <!-- Plain row grid (not a DataGrid) so every numeric cell is a live, single-click textbox. -->
                        <StackPanel Orientation="Vertical" Grid.IsSharedSizeScope="True">
                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="mswc0" MinWidth="50"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="mswc1" MinWidth="120"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="mswc2" MinWidth="130"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="mswc3" MinWidth="100"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="mswc4" MinWidth="100"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="mswc5" MinWidth="100"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="mswc6" MinWidth="100"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="mswc7" MinWidth="50"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Uid="hdr_axis" Grid.Column="0" Text="Axis" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Bottom"/>
                                <TextBlock x:Uid="hdr_travel" Grid.Column="1" Text="Travel (mm)" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Bottom"/>
                                <TextBlock x:Uid="hdr_rate" Grid.Column="2" Text="Rate (mm/min)" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Bottom"/>
                                <TextBlock x:Uid="hdr_steps" Grid.Column="3" Text="Steps/mm" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Bottom"/>
                                <TextBlock x:Uid="hdr_invert" Grid.Column="4" Text="Invert dir ($3)" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Bottom"/>
                                <TextBlock x:Uid="hdr_nclimit" Grid.Column="5" Text="NC limit ($5)" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Bottom"/>
                                <TextBlock x:Uid="hdr_homemin" Grid.Column="6" Text="Home min ($23)" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Bottom"/>
                                <TextBlock x:Uid="hdr_live" Grid.Column="7" Text="Live" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Bottom"/>
                            </Grid>
                            <Separator Margin="0,0,0,2"/>
                            <ItemsControl ItemsSource="{Binding Setup.Axes, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="mswc0" MinWidth="50"/>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="mswc1" MinWidth="120"/>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="mswc2" MinWidth="130"/>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="mswc3" MinWidth="100"/>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="mswc4" MinWidth="100"/>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="mswc5" MinWidth="100"/>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="mswc6" MinWidth="100"/>
                                                <ColumnDefinition Width="Auto" SharedSizeGroup="mswc7" MinWidth="50"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Letter}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <TextBox Grid.Column="1" x:Uid="txt_axTravel" ToolTip="Maximum travel for this axis in mm - sets the soft-limit extent (grbl $130-$132)." Margin="2,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"
                                                     Text="{Binding MaxTravel, UpdateSourceTrigger=PropertyChanged}"/>
                                            <TextBox Grid.Column="2" x:Uid="txt_axRate" ToolTip="Maximum feed rate for this axis in mm/min (grbl $110-$112)." Margin="2,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"
                                                     Text="{Binding MaxRate, UpdateSourceTrigger=PropertyChanged}"/>
                                            <TextBox Grid.Column="3" x:Uid="txt_axSteps" ToolTip="Steps per millimetre for this axis (grbl $100-$102)." Margin="2,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"
                                                     Text="{Binding StepsPerMm, UpdateSourceTrigger=PropertyChanged}"/>
                                            <CheckBox Grid.Column="4" x:Uid="chk_axInvert" ToolTip="Tick to reverse this axis's motion direction (grbl $3 direction-invert mask)." IsChecked="{Binding InvertDirection}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <CheckBox Grid.Column="5" x:Uid="chk_axLimitNC" ToolTip="Tick if this axis's limit switches are wired normally-closed (grbl $5 invert mask)." IsChecked="{Binding LimitNormallyClosed}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <CheckBox Grid.Column="6" x:Uid="chk_axHomeMin" ToolTip="Tick if this axis homes toward its minimum end; untick to home toward the maximum end (grbl $23)." IsChecked="{Binding HomeAtMin}" IsEnabled="{Binding HomingDirEditable}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Border Grid.Column="7" Style="{StaticResource LimitDot}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 4. Homing & limits -->
            <TabItem x:Uid="tabstep_homing" x:Name="tabStepHoming">
                <TabItem.Header><TextBlock x:Uid="step_homing" x:Name="hdrHoming" Text="4 · Homing &amp; limits"/></TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto" MinWidth="220"/>
                        </Grid.ColumnDefinitions>

                        <!-- left: enable toggles (each input carries its own explanation as a tooltip) -->
                        <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,16,0">
                            <CheckBox x:Uid="chk_limitSwitches" Content="My machine has limit switches"
                                      ToolTipService.ShowDuration="20000"
                                      ToolTip="Tick if your axes have limit/home switches wired. With switches, hard limits ($21) are enabled automatically (change that later in Basic settings) and homing becomes available."
                                      IsChecked="{Binding Setup.HasLimitSwitches, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"/>
                            <CheckBox x:Uid="chk_homing" Content="Enable homing ($22)" Margin="0,6,0,0"
                                      ToolTipService.ShowDuration="20000"
                                      ToolTip="Run a homing cycle on connect to find machine zero using the limit switches. Required for soft limits, force-set-origin and click-to-jog."
                                      IsChecked="{Binding Setup.HomingEnable, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"/>
                            <CheckBox x:Uid="chk_forceOrigin" Content="Force set origin at home ($22 bit 3)" Margin="20,2,0,0"
                                      ToolTipService.ShowDuration="20000"
                                      ToolTip="After homing, set machine zero at the home corner so each axis travels positive per its homing direction. Needed for the home-corner choice and the 3D view to match the real machine - reconnect after applying."
                                      IsEnabled="{Binding Setup.HomingEnable, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"
                                      IsChecked="{Binding Setup.ForceSetOrigin, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"/>
                            <CheckBox x:Uid="chk_softLimits" Content="Enable soft limits ($20)" Margin="0,6,0,0"
                                      ToolTipService.ShowDuration="20000"
                                      ToolTip="Stop any move that would exceed the travel you entered, with a clean controlled stop. Requires homing; also enables click-to-jog in the 3D view."
                                      IsChecked="{Binding Setup.SoftLimitsEnable, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"/>
                        </StackPanel>

                        <!-- right: homing rates -->
                        <Grid Grid.Column="1" IsEnabled="{Binding Setup.HomingEnable, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Uid="txt_pulloff" Grid.Row="0" Grid.Column="0" Text="Pull-off / back-off ($27):" VerticalAlignment="Center" Margin="0,3,10,3"
                                       ToolTipService.ShowDuration="20000"
                                       ToolTip="Distance each axis backs off the switch after it trips, in mm. Also the clearance reserved at both ends of travel."/>
                            <TextBox  x:Uid="fld_pulloff" Grid.Row="0" Grid.Column="1" MinWidth="80" ToolTipService.ShowDuration="20000"
                                      ToolTip="Distance each axis backs off the switch after it trips, in mm. Also the clearance reserved at both ends of travel."
                                      Text="{Binding Setup.HomingPulloff, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"/>
                            <TextBlock x:Uid="txt_locate" Grid.Row="1" Grid.Column="0" Text="Locate feed rate ($24):" VerticalAlignment="Center" Margin="0,3,10,3"
                                       ToolTipService.ShowDuration="20000"
                                       ToolTip="Slow feed for the second, precise approach to the switch (mm/min). Lower gives more repeatable homing."/>
                            <TextBox  x:Uid="fld_locate" Grid.Row="1" Grid.Column="1" MinWidth="80" ToolTipService.ShowDuration="20000"
                                      ToolTip="Slow feed for the second, precise approach to the switch (mm/min). Lower gives more repeatable homing."
                                      Text="{Binding Setup.HomingFeed, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"/>
                            <TextBlock x:Uid="txt_seek" Grid.Row="2" Grid.Column="0" Text="Seek rate ($25):" VerticalAlignment="Center" Margin="0,3,10,3"
                                       ToolTipService.ShowDuration="20000"
                                       ToolTip="Fast feed for the first approach that finds the switch (mm/min)."/>
                            <TextBox  x:Uid="fld_seek" Grid.Row="2" Grid.Column="1" MinWidth="80" ToolTipService.ShowDuration="20000"
                                      ToolTip="Fast feed for the first approach that finds the switch (mm/min)."
                                      Text="{Binding Setup.HomingSeek, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"/>
                            <TextBlock x:Uid="txt_debounce" Grid.Row="3" Grid.Column="0" Text="Debounce ms ($26):" VerticalAlignment="Center" Margin="0,3,10,3"
                                       ToolTipService.ShowDuration="20000"
                                       ToolTip="Time the switch signal must stay steady before it counts, in milliseconds. Filters electrical noise and contact bounce."/>
                            <TextBox  x:Uid="fld_debounce" Grid.Row="3" Grid.Column="1" MinWidth="80" ToolTipService.ShowDuration="20000"
                                      ToolTip="Time the switch signal must stay steady before it counts, in milliseconds. Filters electrical noise and contact bounce."
                                      Text="{Binding Setup.HomingDebounce, UpdateSourceTrigger=PropertyChanged, RelativeSource={RelativeSource AncestorType={x:Type local:MachineSetupWizard}}}"/>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <!-- 5. Probe definitions (probes are machine hardware) -->
            <TabItem x:Uid="tabstep_probes" x:Name="tabStepProbes">
                <TabItem.Header><TextBlock x:Uid="step_probes" x:Name="hdrProbes" Text="5 · Probe definitions"/></TabItem.Header>
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" x:Uid="txt_probesDesc" TextWrapping="Wrap" Margin="0,0,0,6"
                               Text="Define the probes fitted to this machine - tip diameter, feeds, clearances and offsets. Used by Load Stock and the probing tabs."/>
                    <DataGrid x:Uid="grdProbes" x:Name="grdProbes" Grid.Row="1" Grid.Column="0" AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" SelectionMode="Single"
                              HeadersVisibility="Column" GridLinesVisibility="All"
                              SelectionChanged="Probes_SelectionChanged" MouseDoubleClick="Probes_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Uid="pdl_name" Header="Name" Binding="{Binding Name}" Width="*" MinWidth="110"/>
                            <DataGridTextColumn x:Uid="pdl_type" Header="Type" Binding="{Binding TypeName}" MinWidth="80"/>
                            <DataGridTextColumn x:Uid="pdl_dia" Header="Tip" Binding="{Binding ProbeDiameter, StringFormat=0.0##}" Width="50"/>
                            <DataGridTextColumn x:Uid="pdl_search" Header="Approach" Binding="{Binding ProbeFeedRate, StringFormat=0}" Width="75"/>
                            <DataGridTextColumn x:Uid="pdl_latch" Header="Re-touch" Binding="{Binding LatchFeedRate, StringFormat=0}" Width="70"/>
                            <DataGridTextColumn x:Uid="pdl_dist" Header="Search dist." Binding="{Binding ProbeDistance, StringFormat=0.0##}" Width="80"/>
                            <DataGridTextColumn x:Uid="pdl_clr" Header="Standoff" Binding="{Binding XYClearance, StringFormat=0.0##}" Width="65"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="1" Grid.Column="1" MinWidth="90" Margin="8,0,0,0">
                        <Button x:Uid="pdl_add" x:Name="btnProbeAdd" Content="Add" Click="ProbeAdd_Click" Margin="0,0,0,4" MinHeight="26"/>
                        <Button x:Uid="pdl_edit" x:Name="btnProbeEdit" Content="Edit" Click="ProbeEdit_Click" Margin="0,0,0,4" MinHeight="26" IsEnabled="False"/>
                        <Button x:Uid="pdl_delete" x:Name="btnProbeDelete" Content="Delete" Click="ProbeDelete_Click" Margin="0,0,0,4" MinHeight="26" IsEnabled="False"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- 6. Fixture definitions (the user's own named workholding fixtures - Start Job selects from these) -->
            <TabItem x:Uid="tabstep_fixtures" x:Name="tabStepFixtures">
                <TabItem.Header><TextBlock x:Uid="step_fixtures" x:Name="hdrFixtures" Text="6 · Fixture definitions"/></TabItem.Header>
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" x:Uid="txt_fixturesDesc" TextWrapping="Wrap" Margin="0,0,0,6"
                               Text="Define the fixtures on this machine (a specific vise, fence, etc.). Add picks the TYPE first - Corner fence, Machinist vise, Dog-hole/grid corner, Vacuum table zero-corner, fixed choices ioSender knows the probe pattern for - which determines which offset fields apply. After OK, jog to the reference and click &quot;Set position&quot; to capture its machine-coordinate start point. Only Corner fence currently generates working g-code."/>
                    <DataGrid x:Uid="grdFixtures" x:Name="grdFixtures" Grid.Row="1" Grid.Column="0" AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" SelectionMode="Single"
                              HeadersVisibility="Column" GridLinesVisibility="All"
                              SelectionChanged="Fixtures_SelectionChanged" MouseDoubleClick="Fixtures_DoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Uid="fxl_name" Header="Name" Binding="{Binding Name}" Width="*" MinWidth="120"/>
                            <DataGridTextColumn x:Uid="fxl_kind" Header="Type" Binding="{Binding KindName}" MinWidth="150"/>
                            <DataGridTextColumn x:Uid="fxl_coords" Header="Position" Binding="{Binding Coords}" MinWidth="200"/>
                            <DataGridCheckBoxColumn x:Uid="fxl_posval" Header="Validated" Binding="{Binding PositionValidated, Mode=OneWay}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="1" Grid.Column="1" MinWidth="90" Margin="8,0,0,0">
                        <Button x:Uid="fxl_add" x:Name="btnFixtureAdd" Content="Add" Click="FixtureAdd_Click" Margin="0,0,0,4" MinHeight="26"/>
                        <Button x:Uid="fxl_edit" x:Name="btnFixtureEdit" Content="Edit" Click="FixtureEdit_Click" Margin="0,0,0,4" MinHeight="26" IsEnabled="False"/>
                        <Button x:Uid="fxl_delete" x:Name="btnFixtureDelete" Content="Delete" Click="FixtureDelete_Click" Margin="0,0,0,10" MinHeight="26" IsEnabled="False"/>
                        <Button x:Uid="fxl_setpos" x:Name="btnFixtureSetPosition" Content="Set position" Click="FixtureSetPosition_Click" Margin="0,0,0,4" MinHeight="26" IsEnabled="False"
                                ToolTip="Store the current machine position as the selected fixture's reference start point."/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- 7. Controller macros (ATC tool-change set + Load Stock corner probe) -->
            <TabItem x:Uid="tabstep_macros" x:Name="tabStepMacros">
                <TabItem.Header><TextBlock x:Uid="step_ctrlMacros" x:Name="hdrMacros" Text="7 · Controller macros"/></TabItem.Header>
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" x:Uid="txt_ctrlMacrosDesc" TextWrapping="Wrap" Margin="0,0,0,6"
                               Text="Controller-side macros on the controller's filesystem: the tool-change macro (tc) and the Start Job corner probe (pcorner). Green = installed and current, orange = out of date, red = missing. Requires an ATC-capable grblHAL with a filesystem."/>
                    <DataGrid x:Uid="grdMacros" x:Name="grdMacros" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                              IsReadOnly="True" SelectionMode="Single" HeadersVisibility="Column" GridLinesVisibility="All">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn x:Uid="msc_name" Header="Name" Width="*" MinWidth="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="2,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#FFC62828"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding State}" Value="Installed">
                                                            <Setter Property="Foreground" Value="ForestGreen"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding State}" Value="Outdated">
                                                            <Setter Property="Foreground" Value="DarkOrange"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn x:Uid="msc_size" Header="Size" Binding="{Binding Size}" Width="80"/>
                            <DataGridTextColumn x:Uid="msc_fs" Header="FS" Binding="{Binding FS}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Uid="btn_installMacros" x:Name="btnInstallMacros" Content="Install ATC macros…" Padding="14,2" MinHeight="26" Click="InstallMacros_Click" Visibility="Collapsed"/>
                        <Button x:Uid="btn_refreshMacros" x:Name="btnRefreshMacros" Content="Refresh" Padding="14,2" MinHeight="26" Margin="8,0,0,0" Click="RefreshMacros_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </local:StretchTabControl>

        <!-- Footer -->
        <DockPanel Grid.Row="2" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock x:Name="txtStatus" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="Gray"/>
                <Button x:Name="btnForget" x:Uid="btn_forget" Content="Forget machine" Padding="14,0" Margin="0,0,6,0" Click="Forget_Click"
                        ToolTip="Clear the remembered machine. The Machine Setup tab will reappear on the next launch (does not change controller settings)."/>
                <Button x:Name="btnReload" x:Uid="btn_reload" Content="Reload" MinWidth="90" Margin="0,0,6,0" Click="Reload_Click"
                        ToolTip="Discard edits and re-read the current settings from the controller."/>
                <Button x:Name="btnPreview" x:Uid="btn_preview" Content="Preview" MinWidth="90" Margin="0,0,6,0" IsEnabled="False" Click="Preview_Click"
                        ToolTip="Show the settings that will change when you Apply. Enabled once you make a change."/>
                <Button x:Name="btnApply" x:Uid="btn_apply" Content="Apply" MinWidth="90" Click="Apply_Click" IsEnabled="False"
                        ToolTipService.ShowDuration="60000" ToolTipOpening="btnApply_ToolTipOpening"
                        ToolTip="Write the changed settings to the controller."/>
            </StackPanel>
        </DockPanel>
    </Grid>
</UserControl>
