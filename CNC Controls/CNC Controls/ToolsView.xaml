<UserControl x:Class="CNC.Controls.ToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CNC.Controls"
             mc:Ignorable="d"
             d:DesignHeight="515" d:DesignWidth="900"
             Loaded="UserControl_Loaded">
    <!-- Sub-tabs are built in code from the layout tree's Tools/"tools" slot (Phase 2b step 3).
         See RegisterTools()/BuildTools() in ToolsView.xaml.cs. -->
    <TabControl x:Name="tabTools" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Width="Auto" Height="Auto" SelectionChanged="tab_SelectionChanged"/>
</UserControl>
