<UserControl x:Class="CNC.Controls.KbdJogGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CNC.Controls"
             mc:Ignorable="d"
             Loaded="KbdJogGridControl_Loaded"
             d:DesignHeight="110" d:DesignWidth="210">
    <UserControl.Resources>
        <Style x:Key="JogCell" TargetType="Button">
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#FFCCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <GroupBox x:Uid="grp_kbdJogging" Header="Keyboard jogging" HorizontalAlignment="Left" VerticalAlignment="Top" MinWidth="210">
        <Grid x:Name="content" Margin="3,2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="{Binding SpeedHeader}" Foreground="#FF57606A" HorizontalAlignment="Center" Margin="0,0,0,2"/>
            <Button x:Uid="s0" x:Name="s0" Grid.Row="1" Tag="0" Style="{StaticResource JogCell}" Click="Speed_Click">
                <TextBlock><Run Text="Slow:  "/><Run Text="{Binding SlowText, Mode=OneWay}"/></TextBlock>
            </Button>
            <Button x:Uid="s1" x:Name="s1" Grid.Row="2" Tag="1" Style="{StaticResource JogCell}" Click="Speed_Click">
                <TextBlock><Run Text="Fast:  "/><Run Text="{Binding FastText, Mode=OneWay}"/></TextBlock>
            </Button>
        </Grid>
    </GroupBox>
</UserControl>
