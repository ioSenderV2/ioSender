<UserControl x:Class="CNC.Controls.OriginControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CNC.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="42" d:DesignWidth="42">
    <UserControl.Resources>
        <local:EnumValueToBooleanConverter x:Key="EnumToEdgeConverter" />
    </UserControl.Resources>
    <Grid Width="42" Height="42" HorizontalAlignment="Left" VerticalAlignment="Top">
        <Grid.RowDefinitions>
            <RowDefinition Height="14" />
            <RowDefinition Height="14" />
            <RowDefinition Height="14" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="14" />
        </Grid.ColumnDefinitions>
        <RadioButton x:Uid="rb_corner_D" IsChecked="{Binding Path=Value, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=D}" ToolTip="Back-left corner (D)." />
        <RadioButton x:Uid="rb_corner_CD" Grid.Column="1" IsChecked="{Binding Path=Value, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=CD}" ToolTip="Middle of the back edge (C-D)." />
        <RadioButton x:Uid="rb_corner_C" Grid.Column="2" IsChecked="{Binding Path=Value, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=C}" ToolTip="Back-right corner (C)." />
        <RadioButton x:Uid="rb_corner_AD" Grid.Row="1"  IsChecked="{Binding Path=Value, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=AD}" ToolTip="Middle of the left edge (A-D)." />
        <RadioButton x:Uid="rb_corner_Center" Grid.Row="1" Grid.Column="1" IsChecked="{Binding Path=Value, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=Center}" ToolTip="Center." />
        <RadioButton x:Uid="rb_corner_CB" Grid.Row="1" Grid.Column="2" IsChecked="{Binding Path=Value, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=CB}" ToolTip="Middle of the right edge (C-B)." />
        <RadioButton x:Uid="rb_corner_A" Grid.Row="2" Grid.Column="0" IsChecked="{Binding Path=Value, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=A}" ToolTip="Front-left corner (A)." />
        <RadioButton x:Uid="rb_corner_AB" Grid.Row="2" Grid.Column="1" IsChecked="{Binding Path=Value, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=AB}" ToolTip="Middle of the front edge (A-B)." />
        <RadioButton x:Uid="rb_corner_B" Grid.Row="2" Grid.Column="2" IsChecked="{Binding Path=Value, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=B}" ToolTip="Front-right corner (B)." />
    </Grid>
</UserControl>
