<UserControl x:Class="CNC.Controls.GrblConfigView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:CNC.Controls"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="515" d:DesignWidth="900"
             Loaded="UserControl_Loaded">
    <UserControl.Resources>
        <!-- MinHeight/MinWidth (not fixed Height/MaxWidth) so the buttons grow with the text at higher DPI /
             text scaling instead of clipping (see the footer). -->
        <Style x:Key="ConfigButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="90" />
            <Setter Property="MinHeight" Value="23" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <!-- Restart button: while enabled (a restart-only change is pending) it slowly pulses red so the user
             can't miss that a relaunch is needed. A custom template is used because the themed Button chrome
             would otherwise paint over the Background, hiding the animation. The pulse runs off the IsEnabled
             trigger, so it starts when the button is enabled and keeps flashing across tab switches until the
             user restarts (the button is never re-disabled). -->
        <Style x:Key="RestartButtonStyle" TargetType="Button" BasedOn="{StaticResource ConfigButtonStyle}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#FFD32F2F" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="2" BorderThickness="1" BorderBrush="#FF8B0000"
                                Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" SnapsToDevicePixels="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="flashStoryboard">
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border"
                                                            Storyboard.TargetProperty="Background.Color"
                                                            From="#FFE53935" To="#FF7A1515" Duration="0:0:1"
                                                            AutoReverse="True" RepeatBehavior="Forever"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="flashStoryboard"/>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <DockPanel>
        <!-- One shared footer for the whole Settings area. Right group = Save settings (hidden when the relevant
             autosave is on) + Restart (shown when a restart-only change fires). Left group = Reset to Default
             (shown on tabs whose panels opt in via ISettingsResettable). The Grbl sub-footer (Reload/Backup/
             Restore/Copy to simulator) shows only on the Grbl tab. Per-tab visibility is set in UpdateFooterForTab. -->
        <StackPanel x:Name="footer" DockPanel.Dock="Bottom" Margin="0,2,0,0">
            <StackPanel x:Name="grblTools" Orientation="Horizontal" Margin="5,0,5,2" Visibility="Collapsed">
                <Button x:Uid="btn_reload" x:Name="btnReload" Content="Reload" Margin="0,0,5,0" Padding="5,0" Click="btnReload_Click" Style="{StaticResource ConfigButtonStyle}" ToolTip="Reload settings from the controller (discards unsaved edits)."/>
                <Button x:Uid="btn_backup" x:Name="btnBackup" Content="Backup" Margin="0,0,5,0" Padding="5,0" Click="btnBackup_Click" Style="{StaticResource ConfigButtonStyle}" ToolTip="Write settings + work offsets to files in the sender folder."/>
                <Button x:Uid="btn_restore" x:Name="btnRestore" Content="Restore" Margin="0,0,5,0" Padding="5,0" Click="btnRestore_Click" Style="{StaticResource ConfigButtonStyle}" ToolTip="Restore settings from a backup / restore point."/>
                <Button x:Uid="btn_copyToSim" x:Name="btnCopyToSim" Content="Copy to simulator" Margin="0,0,5,0" MinWidth="120" Click="btnCopyToSim_Click" Style="{StaticResource ConfigButtonStyle}" ToolTip="Mirror the current settings into the bundled simulator's &quot;My Machine&quot; profile."/>
            </StackPanel>
            <DockPanel Margin="5,0,5,3">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Uid="btn_saveSettings" x:Name="btnSave" Content="Save settings" Margin="5,0,0,0" Padding="5,0" Click="btnSave_Click" Style="{StaticResource ConfigButtonStyle}"/>
                    <Button x:Uid="btn_restart" x:Name="btnRestart" Content="Restart" Margin="5,0,0,0" Padding="5,0" Click="btnRestart_Click" Style="{StaticResource RestartButtonStyle}" Visibility="Collapsed" IsEnabled="False" ToolTip="Relaunch ioSender to apply changes that only take effect at startup. Enabled once such a change is made."/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Uid="btn_resetDefault" x:Name="btnReset" Content="Reset to Default" Padding="8,0" MinWidth="110" Click="btnReset_Click" Style="{StaticResource ConfigButtonStyle}" ToolTip="Reset this tab's settings to their defaults."/>
                </StackPanel>
            </DockPanel>
        </StackPanel>
        <TabControl x:Name="tabConfig" DockPanel.Dock="Top" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" Width="Auto" Height="Auto" SelectionChanged="tab_SelectionChanged">
            <TabItem x:Uid="tab_basicConfig" x:Name="tabGrbl" Header="Grbl">
                <local:GrblConfigControl x:Name="basicConfig" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
            </TabItem>
            <TabItem x:Uid="tab_appConfig" x:Name="tabApp" Header="App">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <WrapPanel x:Name="pnlApp" Orientation="Horizontal" ItemWidth="394" Margin="5"/>
                </ScrollViewer>
            </TabItem>
            <TabItem x:Uid="tab_joggingConfig" x:Name="tabJogging" Header="Jogging">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <WrapPanel x:Name="pnlJogging" Orientation="Horizontal" ItemWidth="394" Margin="5"/>
                </ScrollViewer>
            </TabItem>
            <TabItem x:Uid="tab_gcodeConfig" x:Name="tabGCode" Header="G Code">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <WrapPanel x:Name="pnlGCode" Orientation="Horizontal" ItemWidth="394" Margin="5"/>
                </ScrollViewer>
            </TabItem>
            <TabItem x:Uid="tab_keysConfig" x:Name="tabKeys" Header="Keyboard &amp; Controller"/>
            <TabItem x:Uid="tab_macrosConfig" x:Name="tabMacros" Header="Macros"/>
            <TabItem x:Uid="tab_mainPageConfig" x:Name="tabMainPage" Header="Main Page"/>
        </TabControl>
    </DockPanel>
</UserControl>
