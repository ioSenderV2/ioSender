<UserControl x:Class="CNC.Controls.Lathe.FacingWizard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CNC.Controls.Lathe"
             xmlns:Controls="clr-namespace:CNC.Controls;assembly=CNC.Controls.WPF"
             xmlns:Converters="clr-namespace:CNC.Controls.Lathe"
             mc:Ignorable="d" 
             d:DesignHeight="480" d:DesignWidth="875">
    <UserControl.Resources>
        <Controls:StringCollectionToTextConverter x:Key="GCodeConverter"/>
        <Controls:MultiLineConverter x:Key="ErrorMessageConverter" />
        <Style x:Key="CNCValue" TargetType="Controls:NumericField">
            <Setter Property="Format" Value="{Binding Path=Format, Mode=OneWay}"/>
            <Setter Property="Unit" Value="{Binding Path=Unit, Mode=OneWay}"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="true">
                    <Setter Property="Controls:NumericField.ToolTip">
                        <Setter.Value>
                            <MultiBinding Converter="{StaticResource ErrorMessageConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="(Validation.Errors)" />
                                <Binding RelativeSource="{RelativeSource Self}" Path="(Validation.Errors).Count" />
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="CNCValueSigned" TargetType="Controls:NumericField">
            <Setter Property="Format" Value="{Binding Path=FormatSigned, Mode=OneWay}"/>
            <Setter Property="Unit" Value="{Binding Path=Unit, Mode=OneWay}"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="true">
                    <Setter Property="Controls:NumericField.ToolTip">
                        <Setter.Value>
                            <MultiBinding Converter="{StaticResource ErrorMessageConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="(Validation.Errors)" />
                                <Binding RelativeSource="{RelativeSource Self}" Path="(Validation.Errors).Count" />
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="SpindleErrorStyle" TargetType="local:CssControl">
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="true">
                    <Setter Property="local:CssControl.ToolTip">
                        <Setter.Value>
                            <MultiBinding Converter="{StaticResource ErrorMessageConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="(Validation.Errors)" />
                                <Binding RelativeSource="{RelativeSource Self}" Path="(Validation.Errors).Count" />
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <!-- Rebuilt to the app's standard layout idiom (vertical StackPanel + Auto sizing, MinWidth/MinHeight) so it
         scales cleanly at 125-150% text scaling. The original was an absolute-Margin canvas layout (upstream). -->
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Left">
                <local:ProfileControl x:Name="cbxProfile" ItemsSource="{Binding Path=Profiles}" SelectedItem="{Binding Path=Profile, Mode=TwoWay}" HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Controls:NumericField x:Name="cvStart" Label="Start Z:" Value="{Binding Path=ZStart, Mode=TwoWay}" Style="{StaticResource CNCValueSigned}"/>
                    <Controls:NumericField x:Name="cvTarget" Label="Target Z:" Margin="12,0,0,0" Value="{Binding Path=ZTarget, Mode=TwoWay}" Style="{StaticResource CNCValueSigned}"/>
                    <Controls:NumericField x:Name="cvClearanceZ" Label="Clearance" Margin="12,0,0,0" Value="{Binding Path=ZClearance, Mode=TwoWay}" Style="{StaticResource CNCValue}"/>
                </StackPanel>
                <GroupBox x:Name="groupBox" Header="Diameter" Margin="0,6,0,0">
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <Controls:NumericField x:Name="cvDiameter" Label="Start" Value="{Binding Path=XStart, Mode=TwoWay}" Style="{StaticResource CNCValue}" ToolTip="Measured diameter of stock."/>
                        <Controls:NumericField x:Name="cvTargetX" Label="Target" Margin="12,0,0,0" Value="{Binding Path=XTarget, Mode=TwoWay}" Style="{StaticResource CNCValue}"/>
                        <Controls:NumericField x:Name="cvClearanceX" Label="Clearance" Margin="12,0,0,0" Value="{Binding Path=XClearance, Mode=TwoWay}" Style="{StaticResource CNCValue}"/>
                    </StackPanel>
                </GroupBox>
                <GroupBox x:Name="groupBox2" Header="Cut depths and feed rates" Margin="0,6,0,0">
                    <StackPanel Margin="0,2,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Controls:NumericField x:Name="cvPassDepth" Label="Pass depth:" Value="{Binding Path=Passdepth, Mode=TwoWay}" Style="{StaticResource CNCValue}" ToolTip="Same for radius and diameter mode."/>
                            <Controls:NumericField x:Name="cvFeedRate" Label="Feed rate:" Margin="12,0,0,0" Value="{Binding Path=FeedRate, Mode=TwoWay}" Unit="{Binding Path=FeedrateUnit}" Style="{StaticResource CNCValue}"/>
                            <local:SpringPassControl x:Name="springPasses" Margin="12,0,0,0" VerticalAlignment="Center" Value="{Binding Path=SpringPasses, Mode=TwoWay}" IsPassesEnabled="{Binding Path=IsSpringPassesEnabled, Mode=TwoWay}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <Controls:NumericField x:Name="cvPassDepthLast" Style="{StaticResource CNCValue}" Label="Last pass:" Value="{Binding Path=PassdepthLastPass, Mode=TwoWay}"/>
                            <Controls:NumericField x:Name="cvFeedRateLast" Label="Feed rate:" Margin="12,0,0,0" Value="{Binding Path=FeedRateLastPass, Mode=TwoWay}" Unit="{Binding Path=FeedrateUnit}" Style="{StaticResource CNCValue}"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
                <local:CssControl x:Name="css" HorizontalAlignment="Left" Margin="0,6,0,0" Style="{StaticResource SpindleErrorStyle}"
                    IsCssEnabled="{Binding Path=IsCssEnabled, Mode=TwoWay}"
                    Value="{Binding Path=CssSpeed, Mode=TwoWay}"
                    Unit="{Binding Path=CssUnit}"
                    SpindleDir="{Binding Path=SpindleDir, Mode=TwoWay}"/>
            </StackPanel>
        </ScrollViewer>
        <StackPanel Grid.Row="1" Margin="0,6,0,0">
            <StackPanel Orientation="Horizontal">
                <Button x:Uid="btnCalculate" x:Name="btnCalculate" Content="Calculate" MinWidth="75" MinHeight="24" Padding="8,2" VerticalAlignment="Center" Click="btnCalculate_Click"/>
                <TextBlock TextWrapping="Wrap" Margin="12,0,0,0" VerticalAlignment="Center">
                    <Run x:Uid="txt_warning" Text="Warning! Use with care - only lightly tested!" Foreground="Red" FontWeight="Bold"/>
                </TextBlock>
            </StackPanel>
            <TextBox x:Uid="txtGCode" x:Name="txtGCode" IsReadOnly="True" TextWrapping="Wrap" MinHeight="80" MaxHeight="160" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
                <TextBox.Text>
                    <MultiBinding Converter="{StaticResource GCodeConverter}">
                        <Binding Path="gCode" Mode="OneWay"/>
                        <Binding Path="gCode.Count" Mode="OneWay" />
                    </MultiBinding>
                </TextBox.Text>
            </TextBox>
        </StackPanel>
    </Grid>
</UserControl>
