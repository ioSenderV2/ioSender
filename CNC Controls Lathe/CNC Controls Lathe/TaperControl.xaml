<UserControl x:Class="CNC.Controls.Lathe.TaperControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CNC.Controls.Lathe"
             xmlns:cncontrols="clr-namespace:CNC.Controls;assembly=CNC.Controls.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="28" d:DesignWidth="175">
    <Grid x:Name="grid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="70"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="37*"/>
        </Grid.ColumnDefinitions>
        <CheckBox x:Uid="chkTaper" x:Name="chkTaper" Content="Taper:" IsChecked="{Binding Path=IsTaperEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        <!-- The checkbox above is the field's real (localized) label, so NumericField's own Label is
             suppressed (empty + ColonAt 0); Unit="deg" now lives inside the merged surface instead of a
             separate trailing Label. -->
        <cncontrols:NumericField x:Name="data" Label="" ColonAt="0" Unit="deg" Format="##0" Value="{Binding Path=Value, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" IsEnabled="{Binding IsTaperEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}" Grid.Column="1" Grid.ColumnSpan="2" HorizontalAlignment="Left" Margin="5,0" VerticalAlignment="Center"/>
    </Grid>
</UserControl>
