<UserControl x:Class="CNC.Controls.Lathe.SpringPassControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:cncontrols="clr-namespace:CNC.Controls;assembly=CNC.Controls.WPF"
             xmlns:local="clr-namespace:CNC.Controls.Lathe"
             mc:Ignorable="d" 
             d:DesignHeight="28" d:DesignWidth="175">
    <Grid x:Name="grid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="125"/>
            <ColumnDefinition Width="50"/>
        </Grid.ColumnDefinitions>
        <CheckBox x:Uid="chkSpringPasses" x:Name="chkSpringPasses" Content="Spring passes:" IsChecked="{Binding Path=IsPassesEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        <!-- The checkbox above is the field's real (localized) label, so NumericField's own Label is
             suppressed (empty + ColonAt 0). -->
        <cncontrols:NumericField x:Name="data" Label="" ColonAt="0" Format="#0" IsEnabled="{Binding Path=IsPassesEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="{Binding Path=Value, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}" Grid.Column="1" HorizontalAlignment="Left" Margin="5,0,0,0" VerticalAlignment="Center"/>
    </Grid>
</UserControl>
