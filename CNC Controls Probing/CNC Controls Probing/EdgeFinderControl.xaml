<UserControl x:Class="CNC.Controls.Probing.EdgeFinderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:Controls="clr-namespace:CNC.Controls;assembly=CNC.Controls.WPF"
             xmlns:local="clr-namespace:CNC.Controls.Probing"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             d:DesignHeight="430" d:DesignWidth="700">
    <UserControl.Resources>
        <system:String x:Uid="str_EdgeFinderInstructions" x:Key="Instructions">Click edge, corner or center in image above to select probing action.\nMove the probe to above the position indicated by green dot before start.</system:String>
        <system:String x:Uid="str_edgeFinderType" x:Key="SelectType">Select edge or corner to probe by clicking on the relevant part of the image above.</system:String>
        <system:String x:Uid="str_edgeFinderInitFailed" x:Key="PositionUnknown">Probing failed, machine position not known.</system:String>
        <system:String x:Uid="str_edgeFinderFailed" x:Key="ProbingFailed">Probing failed</system:String>
        <system:String x:Uid="str_edgeFinderCompleted" x:Key="ProbingCompleted">Probing completed.</system:String>
        <Controls:LogicalNotConverter x:Key="IsNotRunningConverter" />
        <Controls:LogicalAndConverter x:Key="LogicalAndConverter"/>
        <Controls:EnumValueToBooleanConverter x:Key="EnumToEdgeConverter" />
        <Controls:BoolToVisibleConverter x:Key="ToVisibleConverter" />
        <local:EnumValueToVisibleConverter x:Key="ZProbeIsVisibleConverter"/>
        <Style x:Key="ButtonStyleNoHighlighting" TargetType="Button" BasedOn="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="{TemplateBinding Background}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="MouseOver"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ZProbe" TargetType="Rectangle">
            <Setter Property="Fill" Value="Red"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Flag" TargetType="RadioButton">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="GroupName" Value="edge"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Background="Transparent">
                            <Image Source="{Binding Path=Content, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="345"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- Left: scrolling inputs + the action picker; Start/Stop pinned at the column bottom -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Vertical" Margin="5,0,5,0">
                    <local:CsSelectControl/>
                    <GroupBox x:Uid="grp_clearances" Header="Clearances">
                        <StackPanel Orientation="Vertical">
                            <Controls:NumericField x:Uid="fld_xyClearance" Label="XY clearance:" ColonAt="95" Tooltip2="Initial distance away from face to probe" Value="{Binding Path=XYClearance, Mode=TwoWay}" IsEnabled="{Binding Path=XYOffsetEnable}" Margin="0,2,0,0"/>
                            <Controls:NumericField x:Uid="fld_offset" Label="Offset:" ColonAt="95" ToolTip="Distance from corner to probe" Value="{Binding Path=Offset, Mode=TwoWay}" IsEnabled="{Binding Path=OffsetEnable}" Margin="0,2,0,0"/>
                            <Controls:NumericField x:Uid="fld_depth" Label="Depth:" ColonAt="95" ToolTip="Z offset from current position where probing will take place" Value="{Binding Path=Depth, Mode=TwoWay}" IsEnabled="{Binding Path=XYOffsetEnable}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </GroupBox>
                    <GroupBox x:Uid="grp_prbeProperties" Header="Probe/touchplate XY offsets" IsEnabled="{Binding Path=XYOffsetEnable}">
                        <StackPanel Orientation="Vertical">
                            <StackPanel Orientation="Horizontal">
                                <Controls:NumericField x:Uid="fld_probeOffsetX" Label="X:" ToolTip="X offset from probe to controlled point" Value="{Binding Path=ProbeOffsetX, Mode=TwoWay}" ColonAt="20" Margin="0,2,0,0"/>
                                <Controls:NumericField x:Uid="fld_probeOffsetY" Label="Y:" ToolTip="Y offset from probe to controlled point" Value="{Binding Path=ProbeOffsetY, Mode=TwoWay}" ColonAt="20" Margin="8,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Uid="lbl_touchPlateXY" Content="Is touch plate" ToolTip="Offsets are horizontal thickness of touchplate" Margin="19,4,0,0" IsChecked="{Binding Path=TouchPlateIsXY}" IsEnabled="{Binding Path=TouchPlateXYEnabled}" />
                        </StackPanel>
                    </GroupBox>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,4">
                        <CheckBox x:Uid="lbl_probeZ" Content="Probe Z" VerticalAlignment="Center" IsChecked="{Binding Path=ProbeZ}" IsEnabled="{Binding ElementName=probez, Path=IsChecked, Converter={StaticResource IsNotRunningConverter}}"/>
                        <CheckBox x:Uid="lbl_preview" Content="Preview" Margin="15,0,0,0" VerticalAlignment="Center" IsChecked="{Binding Path=PreviewEnable}"/>
                    </StackPanel>
                    <!-- Touch-plate thickness only matters when also probing Z through a plate; hidden otherwise. -->
                    <Controls:NumericField x:Uid="lbl_touchPlate" Label="Touch plate:" ColonAt="95" ToolTip="Touch plate thickness when probing Z through a plate (0 for a bare-surface 3D probe)" Value="{Binding Path=TouchPlateHeight, Mode=TwoWay}" Visibility="{Binding Path=ProbeZ, Converter={StaticResource ToVisibleConverter}}" Margin="0,0,0,4"/>
                    <Grid x:Uid="grd_action" ToolTip="Click edge, corner or center to select probing action." Width="180" Height="180" Margin="0,4,0,4" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="60" />
                            <RowDefinition Height="60" />
                            <RowDefinition Height="60" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="60" />
                            <ColumnDefinition Width="60" />
                        </Grid.ColumnDefinitions>
                        <RadioButton Content="Resources/cornerD.png" Style="{StaticResource Flag}" IsChecked="{Binding Path=ProbeEdge, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=D}" />
                        <RadioButton Content="Resources/edgeCD.png" Grid.Column="1" Style="{StaticResource Flag}" IsChecked="{Binding Path=ProbeEdge, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=CD}" />
                        <RadioButton Content="Resources/cornerC.png" Grid.Column="2" Style="{StaticResource Flag}" IsChecked="{Binding Path=ProbeEdge, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=C}" />
                        <RadioButton Content="Resources/edgeAD.png" Grid.Row="1" Style="{StaticResource Flag}" IsChecked="{Binding Path=ProbeEdge, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=AD}" />
                        <RadioButton x:Name="probez" Content="Resources/edgeZ.png" Grid.Row="1" Grid.Column="1" Style="{StaticResource Flag}" IsChecked="{Binding Path=ProbeEdge, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=Z}" />
                        <RadioButton Content="Resources/edgeBC.png" Grid.Row="1" Grid.Column="2" Style="{StaticResource Flag}" IsChecked="{Binding Path=ProbeEdge, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=CB}" />
                        <RadioButton Content="Resources/cornerA.png" Grid.Row="2" Grid.Column="0" Style="{StaticResource Flag}" IsChecked="{Binding Path=ProbeEdge, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=A}" />
                        <RadioButton Content="Resources/edgeAB.png" Grid.Row="2" Grid.Column="1" Style="{StaticResource Flag}" IsChecked="{Binding Path=ProbeEdge, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=AB}" />
                        <RadioButton Content="Resources/cornerB.png" Grid.Row="2" Grid.Column="2" Style="{StaticResource Flag}" IsChecked="{Binding Path=ProbeEdge, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=B}" />
                        <Rectangle Margin="35,35,0,0" Style="{StaticResource ZProbe}">
                            <Rectangle.Visibility>
                                <MultiBinding Converter="{StaticResource ZProbeIsVisibleConverter}" ConverterParameter="D">
                                    <Binding Path="ProbeEdge"/>
                                    <Binding Path="ProbeZ"/>
                                </MultiBinding>
                            </Rectangle.Visibility>
                        </Rectangle>
                        <Rectangle Grid.Column="1" Margin="0,35,0,0" Style="{StaticResource ZProbe}">
                            <Rectangle.Visibility>
                                <MultiBinding Converter="{StaticResource ZProbeIsVisibleConverter}" ConverterParameter="CD">
                                    <Binding Path="ProbeEdge"/>
                                    <Binding Path="ProbeZ"/>
                                </MultiBinding>
                            </Rectangle.Visibility>
                        </Rectangle>
                        <Rectangle Grid.Column="2" Margin="0,35,35,0" Style="{StaticResource ZProbe}">
                            <Rectangle.Visibility>
                                <MultiBinding Converter="{StaticResource ZProbeIsVisibleConverter}" ConverterParameter="C">
                                    <Binding Path="ProbeEdge"/>
                                    <Binding Path="ProbeZ"/>
                                </MultiBinding>
                            </Rectangle.Visibility>
                        </Rectangle>
                        <Rectangle Grid.Row="1"  Margin="35,0,0,0" Style="{StaticResource ZProbe}">
                            <Rectangle.Visibility>
                                <MultiBinding Converter="{StaticResource ZProbeIsVisibleConverter}" ConverterParameter="AD">
                                    <Binding Path="ProbeEdge"/>
                                    <Binding Path="ProbeZ"/>
                                </MultiBinding>
                            </Rectangle.Visibility>
                        </Rectangle>
                        <Rectangle Grid.Row="1" Grid.Column="1" Style="{StaticResource ZProbe}">
                            <Rectangle.Visibility>
                                <MultiBinding Converter="{StaticResource ZProbeIsVisibleConverter}" ConverterParameter="Z">
                                    <Binding Path="ProbeEdge"/>
                                    <Binding Path="ProbeZ"/>
                                </MultiBinding>
                            </Rectangle.Visibility>
                        </Rectangle>
                        <Rectangle Grid.Row="1" Grid.Column="2" Margin="0,0,35,0"  HorizontalAlignment="Center" Style="{StaticResource ZProbe}">
                            <Rectangle.Visibility>
                                <MultiBinding Converter="{StaticResource ZProbeIsVisibleConverter}" ConverterParameter="CB">
                                    <Binding Path="ProbeEdge"/>
                                    <Binding Path="ProbeZ"/>
                                </MultiBinding>
                            </Rectangle.Visibility>
                        </Rectangle>
                        <Rectangle Grid.Row="2" Margin="35,0,0,35" Style="{StaticResource ZProbe}">
                            <Rectangle.Visibility>
                                <MultiBinding Converter="{StaticResource ZProbeIsVisibleConverter}" ConverterParameter="A">
                                    <Binding Path="ProbeEdge"/>
                                    <Binding Path="ProbeZ"/>
                                </MultiBinding>
                            </Rectangle.Visibility>
                        </Rectangle>
                        <Rectangle Grid.Row="2" Grid.Column="1" Margin="0,0,0,35" Style="{StaticResource ZProbe}">
                            <Rectangle.Visibility>
                                <MultiBinding Converter="{StaticResource ZProbeIsVisibleConverter}" ConverterParameter="AB">
                                    <Binding Path="ProbeEdge"/>
                                    <Binding Path="ProbeZ"/>
                                </MultiBinding>
                            </Rectangle.Visibility>
                        </Rectangle>
                        <Rectangle Grid.Row="2" Grid.Column="2" Margin="0,0,35,35" Style="{StaticResource ZProbe}">
                            <Rectangle.Visibility>
                                <MultiBinding Converter="{StaticResource ZProbeIsVisibleConverter}" ConverterParameter="B">
                                    <Binding Path="ProbeEdge"/>
                                    <Binding Path="ProbeZ"/>
                                </MultiBinding>
                            </Rectangle.Visibility>
                        </Rectangle>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
            <StackPanel Grid.Row="1" Margin="5,4,5,6" Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Uid="btn_start" Content="Start" IsEnabled="{Binding Path=Grbl.IsJobRunning, Converter={StaticResource IsNotRunningConverter}}" Margin="0,0,4,0" Width="75" Click="start_Click"/>
                <Button x:Uid="btn_stop" Content="Stop" IsEnabled="{Binding Path=Grbl.IsJobRunning}" Margin="0" Width="75" Click="stop_Click"/>
            </StackPanel>
        </Grid>
        <!-- Right: description on top, output (position / preview / result) below -->
        <Grid Grid.Column="1" Margin="10,0,5,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,2,0,0">
                <Run x:Uid="str_edgeExtDescription" Text="Find work X/Y zero (and optionally Z) on the OUTSIDE of a workpiece. Click an edge, corner or the centre (Z) in the picker, jog the probe over the green dot, then Start. Tick Probe Z to also touch the top and set Z0. The result is applied as a coordinate-system origin (G10), a temporary offset (G92), or just measured. Probe: 3D probe or edge/touch plate."/>
                <LineBreak/><LineBreak/>
                <Run Text="{Binding Path=Instructions, Mode=OneWay}"/>
                <LineBreak/><LineBreak/>
                <Run x:Uid="txt_warning" Text="Warning! Use with care - incorrect parameters may damage your probe!" Foreground="Red" FontWeight="Bold"/>
            </TextBlock>
            <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,10,0,0">
                <TextBlock Text="{Binding Path=Position, Mode=OneWay}" TextWrapping="NoWrap" Margin="0,0,0,6"/>
                <TextBlock Text="{Binding Path=Message, Mode=OneWay}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                <TextBox IsReadOnly="True" Text="{Binding Path=PreviewText, Mode=OneWay}" TextWrapping="NoWrap"
                         Visibility="{Binding Path=PreviewEnable, Converter={StaticResource ToVisibleConverter}}"
                         Height="200" FontSize="10" FontFamily="Verdana"
                         ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
