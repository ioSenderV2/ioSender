<UserControl x:Class="CNC.Controls.Probing.RotationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:system="clr-namespace:System;assembly=mscorlib"
             xmlns:Controls="clr-namespace:CNC.Controls;assembly=CNC.Controls.WPF"
             xmlns:local="clr-namespace:CNC.Controls.Probing"
             mc:Ignorable="d"
             d:DesignHeight="430" d:DesignWidth="700">
    <UserControl.Resources>
        <system:String x:Uid="str_rotationInstructions" x:Key="Instructions">Click edge in image above to select probing action.\nMove the probe to above the position indicated by green dot before start.</system:String>
        <system:String x:Uid="str_rotationType" x:Key="SelectType">Select edge to probe by clicking on the relevant part of the image above.</system:String>
        <system:String x:Uid="str_rotationInitFailed" x:Key="ProbedAngle">Angle: {0} deg</system:String>
        <system:String x:Uid="str_rotationFailed" x:Key="ProbingFailed">Probing failed</system:String>
        <system:String x:Uid="str_rotationCompleted" x:Key="ProbingCompleted">Probing completed.</system:String>
        <Controls:LogicalNotConverter x:Key="IsNotRunningConverter" />
        <Controls:EnumValueToBooleanConverter x:Key="EnumToEdgeConverter" />
        <Controls:BoolToVisibleConverter x:Key="ToVisibleConverter" />
        <local:OriginToBooleanConverter x:Key="UseX0Y0Converter" />
        <local:OriginToCurrentPositionConverter x:Key="UseXYConverter" />
        <local:EnumValueToVisibleConverter x:Key="ZProbeIsVisibleConverter" />
        <Style x:Key="Flag" TargetType="RadioButton">
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="80"/>
            <Setter Property="Height" Value="80"/>
            <Setter Property="GroupName" Value="edge"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Background="Transparent">
                            <Image Source="{Binding Path=Content, RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="345"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- Left: inputs + the edge picker; Start/Stop/Apply pinned at the column bottom -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Vertical" Margin="5,0,5,0">
                    <local:CsSelectControl/>
                    <GroupBox x:Uid="grp_workpieceOffset" Header="Also set work origin" ToolTip="As well as the angle, probe a second edge to find the X0,Y0 corner and set the work origin." Margin="0,4,0,0">
                        <CheckBox x:Uid="lbl_addOffset" Content="Determine X0,Y0 for right angled workpiece" ToolTip="Adds a probe point on the left edge." IsChecked="{Binding Path=AddAction, Mode=TwoWay}" Margin="5,7,0,5" VerticalAlignment="Center"/>
                    </GroupBox>
                    <GroupBox x:Uid="grp_RotationCenter" Header="Rotation center" Margin="0,4,0,0" ToolTip="Click to select rotation center relative to job, if not selected X0,Y0 is used.">
                        <StackPanel Orientation="Horizontal">
                            <Controls:OriginControl Value="{Binding Path=Origin, Mode=TwoWay}" IsEnabled="{Binding Path=Grbl.IsFileLoaded}" Margin="5,5,0,0"/>
                            <StackPanel Orientation="Vertical" Margin="8,18,5,3">
                                <CheckBox x:Uid="chk_useXY" Content="Use X,Y" IsEnabled="{Binding Path=Grbl.IsFileLoaded}" IsChecked="{Binding Path=Origin, Mode=TwoWay, Converter={StaticResource UseXYConverter}}"/>
                                <CheckBox x:Uid="chk_useX0Y0" Content="Use X0,Y0" IsEnabled="{Binding Path=Grbl.IsFileLoaded}" IsChecked="{Binding Path=Origin, Mode=TwoWay, Converter={StaticResource UseX0Y0Converter}}"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,4">
                        <CheckBox x:Uid="lbl_preview" Content="Preview" VerticalAlignment="Center" IsChecked="{Binding Path=PreviewEnable}"/>
                    </StackPanel>
                    <Grid x:Name="grd_action" x:Uid="grd_action" ToolTip="Click edge to select probing action." Width="160" Height="160" Margin="0,4,0,4" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="80" />
                            <RowDefinition Height="80" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <RadioButton Content="Resources/RotaterAD.png" Style="{StaticResource Flag}" IsChecked="{Binding Path=ProbeEdge, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=AD}" />
                        <RadioButton Content="Resources/RotaterCD.png" Grid.Column="2" Style="{StaticResource Flag}" IsChecked="{Binding Path=ProbeEdge, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=CD}" />
                        <RadioButton Content="Resources/RotaterAB.png" Grid.Row="1" Grid.Column="0" Style="{StaticResource Flag}" IsChecked="{Binding Path=ProbeEdge, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=AB}" />
                        <RadioButton Content="Resources/RotaterCB.png" Grid.Row="1" Grid.Column="1" Style="{StaticResource Flag}" IsChecked="{Binding Path=ProbeEdge, Mode=TwoWay, Converter={StaticResource EnumToEdgeConverter}, ConverterParameter=CB}" />
                    </Grid>
                </StackPanel>
            </ScrollViewer>
            <StackPanel Grid.Row="1" Margin="5,4,5,6" Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Uid="btn_start" Content="Start" IsEnabled="{Binding Path=Grbl.IsJobRunning, Converter={StaticResource IsNotRunningConverter}}" Margin="0,0,4,0" MinWidth="75" Click="start_Click"/>
                <Button x:Uid="btn_stop" Content="Stop" IsEnabled="{Binding Path=Grbl.IsJobRunning}" Margin="0,0,4,0" MinWidth="75" Click="stop_Click"/>
                <Button x:Uid="btn_apply" Content="_Apply" IsEnabled="{Binding Path=CanApplyTransform}" Margin="0" MinWidth="75" Click="apply_Click"/>
            </StackPanel>
        </Grid>
        <!-- Right: description on top, output below -->
        <Grid Grid.Column="1" Margin="10,0,5,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,2,0,0">
                <Run x:Uid="str_rotationDescription" Text="Use when the workpiece is clamped at an angle (not square to the machine): this measures the skew and rotates the loaded G-code to match, so you don't have to re-clamp it square. Click an edge, probe two points along it; the angle is shown, and Apply rotates the program about the chosen centre. Tick 'Also set work origin' to also find the X0,Y0 corner in the same run. Probe: 3D probe or touch plate."/>
                <LineBreak/><LineBreak/>
                <Run Text="{Binding Path=Instructions, Mode=OneWay}"/>
                <LineBreak/><LineBreak/>
                <Run x:Uid="txt_warning" Text="Warning! Use with care - incorrect parameters may damage your probe!" Foreground="Red" FontWeight="Bold"/>
            </TextBlock>
            <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,10,0,0">
                <TextBlock Text="{Binding Path=Position, Mode=OneWay}" TextWrapping="NoWrap" Margin="0,0,0,6"/>
                <TextBlock Text="{Binding Path=Message, Mode=OneWay}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                <TextBox IsReadOnly="True" Text="{Binding Path=PreviewText, Mode=OneWay}" TextWrapping="NoWrap"
                         Visibility="{Binding Path=PreviewEnable, Converter={StaticResource ToVisibleConverter}}"
                         Height="160" FontSize="10" FontFamily="Verdana"
                         ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
